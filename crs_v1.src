// Grey Hack CRS suite
// Phase 8: bootstrap, discovery/ranking, attack flow, router/file exploit adaptation, staging, post-foothold intel, chain-local enrichment, manual assist, mission tasking, loot collection, cleanup, and final handoff.

NL = char(10)
CR = char(13)
TAB = char(9)
DEFAULT_MODE = "auto"
DEFAULT_OUTPUT_FOLDER = "crs"
SCRIPT_BUILD = "2026-04-06-phase8-router-file-a"
DEFAULT_ROOT_BOOTSTRAP_USER = "root"
DEFAULT_ROOT_BOOTSTRAP_PASSWORD = "admin"
DEFAULT_PERSISTENCE_BOOTSTRAP_USER = "admin"
DEFAULT_PERSISTENCE_BOOTSTRAP_PASSWORD = "admin"
DEFAULT_MAX_PIVOT_DEPTH = 2
MAX_CREDENTIAL_FILES = 40
MAX_CREDENTIAL_LINES = 60
MAX_CREDENTIAL_CANDIDATES = 40
MAX_CREDENTIAL_ATTEMPTS = 80
MAX_MANUAL_ASSIST_OPTIONS = 12
CREDENTIAL_KEYWORDS = ["pass", "passwd", "password", "pwd", "user", "username", "login", "credential", "secret", "token", "auth", "ftp", "ssh", "mail", "bank", "wallet", "card", "pin", "config"]
TOKEN_CHARS = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789_-.:@/$"

appendLine = function(lines, text)
  lines.push(text)
end function

isError = function(value)
  return value isa string and value != ""
end function

isApiSuccess = function(value)
  if value == null then return 0
  if isError(value) then return 0
  if value == 0 then return 0
  return 1
end function

normalizeInput = function(value, defaultValue = "")
  if value == null then return defaultValue
  return str(value)
end function

normalizeText = function(value, defaultValue = "")
  clean = ""

  for ch in normalizeInput(value, defaultValue)
    if ch != CR then clean = clean + ch
  end for

  return clean
end function

toYesNoFlag = function(inputValue, defaultValue = 1)
  lowered = normalizeInput(inputValue).trim.lower
  if lowered == "" then return defaultValue
  if lowered == "y" or lowered == "yes" or lowered == "1" or lowered == "true" then return 1
  if lowered == "n" or lowered == "no" or lowered == "0" or lowered == "false" then return 0
  return defaultValue
end function

normalizeRunMode = function(inputValue, defaultValue = DEFAULT_MODE)
  lowered = normalizeInput(inputValue).trim.lower
  if lowered == "" then return defaultValue
  if lowered == "auto" or lowered == "a" then return "auto"
  if lowered == "public" or lowered == "internet" then return "public"
  if lowered == "lan" or lowered == "internal" then return "lan"
  if lowered == "router" or lowered == "gateway" then return "router"
  if lowered == "worker" then return "worker"
  return defaultValue
end function

normalizeCleanupMode = function(inputValue, defaultValue = "prompt")
  lowered = normalizeInput(inputValue).trim.lower
  if lowered == "" then return defaultValue
  if lowered == "off" then return "off"
  if lowered == "prompt" then return "prompt"
  if lowered == "safe" then return "safe"
  if lowered == "wipe" then return "wipe"
  return defaultValue
end function

normalizeMissionActionMode = function(inputValue, defaultValue = "loot")
  lowered = normalizeInput(inputValue).trim.lower
  if lowered == "" then return defaultValue
  if lowered == "off" then return "off"
  if lowered == "loot" then return "loot"
  if lowered == "passwd" then return "passwd"
  if lowered == "mail" then return "mail"
  if lowered == "bank" then return "bank"
  if lowered == "all" then return "all"
  return defaultValue
end function

getParamValue = function(flagName, defaultValue = "")
  if params == null then return defaultValue

  flagIndex = params.indexOf(flagName)
  if flagIndex == null then return defaultValue

  nextIndex = flagIndex + 1
  if not params.hasIndex(nextIndex) then return defaultValue
  return params[nextIndex]
end function

getParamFlag = function(flagName, defaultValue = 0)
  return toYesNoFlag(getParamValue(flagName, ""), defaultValue)
end function

isNumericText = function(textValue)
  text = normalizeInput(textValue).trim
  if text == "" then return 0

  for ch in text
    if ch < "0" or ch > "9" then return 0
  end for

  return 1
end function

isValidIpAddress = function(ipAddress)
  ipText = normalizeInput(ipAddress).trim
  if ipText == "" then return 0
  return is_valid_ip(ipText)
end function

splitIpParts = function(ipAddress)
  ipText = normalizeInput(ipAddress).trim
  if ipText == "" then return []
  return ipText.split("\\.")
end function

isLikelyRouterLanIp = function(ipAddress)
  if not isValidIpAddress(ipAddress) then return 0
  if not is_lan_ip(ipAddress) then return 0

  parts = splitIpParts(ipAddress)
  if parts == null or parts.len != 4 then return 0
  return parts[3] == "1"
end function

buildHostKey = function(publicIp, localIp)
  return normalizeInput(publicIp).trim + TAB + normalizeInput(localIp).trim
end function

listHasValue = function(items, wanted)
  if items == null then return 0

  for item in items
    if item == wanted then return 1
  end for

  return 0
end function

pushUniqueString = function(values, seen, rawValue)
  valueText = normalizeInput(rawValue).trim
  if valueText == "" then return 0
  if listHasValue(seen, valueText) then return 0

  seen.push(valueText)
  values.push(valueText)
  return 1
end function

ensureFolder = function(computer, parentPath, folderName)
  folderPath = parentPath + "/" + folderName
  folder = computer.File(folderPath)
  if folder != null then
    if not folder.is_folder then return null
    if not folder.has_permission("w") then return null
    return folderPath
  end if

  created = computer.create_folder(parentPath, folderName)
  if isError(created) then return null

  folder = computer.File(folderPath)
  if folder == null then return null
  if not folder.is_folder then return null
  if not folder.has_permission("w") then return null
  return folderPath
end function

ensureTextFile = function(computer, dirPath, fileName)
  filePath = dirPath + "/" + fileName
  file = computer.File(filePath)
  if file != null then
    if file.is_folder then return null
    if file.is_binary then return null
    if not file.has_permission("w") then return null
    return file
  end if

  created = computer.touch(dirPath, fileName)
  if isError(created) then return null

  file = computer.File(filePath)
  if file == null then return null
  if file.is_folder then return null
  if file.is_binary then return null
  if not file.has_permission("w") then return null
  return file
end function

readTextFile = function(file)
  if file == null then return null
  if file.is_folder then return null
  if file.is_binary then return null
  if not file.has_permission("r") then return null
  return normalizeText(file.get_content)
end function

extractUnsafeValues = function(scanInfo)
  values = []
  seen = []
  remaining = normalizeInput(scanInfo)

  while 1
    tagStart = remaining.indexOf("<b>")
    if tagStart == null then break

    remaining = remaining[tagStart + 3:]
    tagEnd = remaining.indexOf("</b>")
    if tagEnd == null then break

    candidate = remaining[0:tagEnd]
    if candidate != "" and not listHasValue(seen, candidate) then
      seen.push(candidate)
      values.push(candidate)
    end if

    if tagEnd + 4 >= remaining.len then break
    remaining = remaining[tagEnd + 4:]
  end while

  return values
end function

buildCacheSignatureKey = function(libName, libVersion, portNumber, memoryAddress, unsafeValue)
  return normalizeInput(libName).trim + TAB + normalizeInput(libVersion).trim + TAB + normalizeInput(portNumber).trim + TAB + normalizeInput(memoryAddress).trim + TAB + normalizeInput(unsafeValue).trim
end function

loadSignatureCache = function(cacheFile)
  cacheData = {
    "records": [],
    "lines": [],
    "keys": [],
  }

  if cacheFile == null then return cacheData
  if not cacheFile.has_permission("r") then return cacheData

  content = normalizeInput(cacheFile.get_content)
  if content == "" then return cacheData

  for line in content.split(NL)
    cleanLine = normalizeInput(line).trim
    if cleanLine == "" then continue

    parts = cleanLine.split(TAB)
    if parts == null or parts.len < 6 then continue
    if parts[0] == "lib" and parts[1] == "version" then continue

    signatureKey = buildCacheSignatureKey(parts[0], parts[1], parts[2], parts[3], parts[4])
    if listHasValue(cacheData.keys, signatureKey) then continue

    cacheData.keys.push(signatureKey)
    cacheData.lines.push(cleanLine)
    cacheData.records.push({
      "lib": parts[0],
      "version": parts[1],
      "port": parts[2],
      "memory": parts[3],
      "unsafe": parts[4],
      "type": parts[5],
    })
  end for

  return cacheData
end function

saveSignatureCache = function(cacheFile, cacheData)
  if cacheFile == null then return "Missing signature cache file"

  lines = ["lib" + TAB + "version" + TAB + "port" + TAB + "memory" + TAB + "unsafe" + TAB + "type"]
  if cacheData != null and cacheData.lines != null then
    for cacheLine in cacheData.lines
      appendLine(lines, cacheLine)
    end for
  end if

  return cacheFile.set_content(lines.join(NL))
end function

addSignatureCacheRecord = function(cacheData, libName, libVersion, portNumber, memoryAddress, unsafeValue, resultType)
  if cacheData == null then return 0

  portText = normalizeInput(portNumber).trim
  signatureKey = buildCacheSignatureKey(libName, libVersion, portText, memoryAddress, unsafeValue)
  if listHasValue(cacheData.keys, signatureKey) then return 0

  cacheData.keys.push(signatureKey)
  cacheLine = normalizeInput(libName).trim + TAB + normalizeInput(libVersion).trim + TAB + portText + TAB + normalizeInput(memoryAddress).trim + TAB + normalizeInput(unsafeValue).trim + TAB + normalizeInput(resultType).trim
  cacheData.lines.push(cacheLine)
  cacheData.records.push({
    "lib": normalizeInput(libName).trim,
    "version": normalizeInput(libVersion).trim,
    "port": portText,
    "memory": normalizeInput(memoryAddress).trim,
    "unsafe": normalizeInput(unsafeValue).trim,
    "type": normalizeInput(resultType).trim,
  })
  return 1
end function

findCachedSignatures = function(cacheData, libName, libVersion, portNumber)
  matches = []
  if cacheData == null or cacheData.records == null then return matches

  wantedLib = normalizeInput(libName).trim
  wantedVersion = normalizeInput(libVersion).trim
  wantedPort = normalizeInput(portNumber).trim

  for record in cacheData.records
    if record == null then continue
    if record.lib == wantedLib and record.version == wantedVersion and record.port == wantedPort then
      matches.push(record)
    end if
  end for

  if matches.len > 0 then return matches

  for record in cacheData.records
    if record == null then continue
    if record.lib == wantedLib and record.version == wantedVersion then
      matches.push(record)
    end if
  end for

  return matches
end function

normalizeCacheField = function(value)
  clean = ""

  for ch in normalizeText(value).trim
    if ch == TAB or ch == NL then
      clean = clean + " "
    else
      clean = clean + ch
    end if
  end for

  return clean
end function

buildCredentialCacheKey = function(hostPublic, hostLocal, userName, passwordValue)
  return normalizeCacheField(hostPublic) + TAB + normalizeCacheField(hostLocal) + TAB + normalizeCacheField(userName) + TAB + normalizeCacheField(passwordValue)
end function

loadCredentialCache = function(cacheFile)
  cacheData = {
    "records": [],
    "lines": [],
    "keys": [],
  }

  if cacheFile == null then return cacheData
  if not cacheFile.has_permission("r") then return cacheData

  content = normalizeInput(cacheFile.get_content)
  if content == "" then return cacheData

  for line in content.split(NL)
    cleanLine = normalizeInput(line).trim
    if cleanLine == "" then continue

    parts = cleanLine.split(TAB)
    if parts == null or parts.len < 5 then continue
    if parts[0] == "host_public" and parts[1] == "host_local" then continue

    recordKey = buildCredentialCacheKey(parts[0], parts[1], parts[2], parts[3])
    if listHasValue(cacheData.keys, recordKey) then continue

    cacheData.keys.push(recordKey)
    cacheData.lines.push(cleanLine)
    cacheData.records.push({
      "host_public": parts[0],
      "host_local": parts[1],
      "user": parts[2],
      "password": parts[3],
      "source": parts[4],
    })
  end for

  return cacheData
end function

saveCredentialCache = function(cacheFile, cacheData)
  if cacheFile == null then return "Missing credential cache file"

  lines = ["host_public" + TAB + "host_local" + TAB + "user" + TAB + "password" + TAB + "source"]
  if cacheData != null and cacheData.lines != null then
    for cacheLine in cacheData.lines
      appendLine(lines, cacheLine)
    end for
  end if

  return cacheFile.set_content(lines.join(NL))
end function

addCredentialCacheRecord = function(cacheData, hostPublic, hostLocal, userName, passwordValue, sourceText)
  if cacheData == null then return 0

  recordKey = buildCredentialCacheKey(hostPublic, hostLocal, userName, passwordValue)
  if listHasValue(cacheData.keys, recordKey) then return 0

  cacheData.keys.push(recordKey)
  cacheLine = normalizeCacheField(hostPublic) + TAB + normalizeCacheField(hostLocal) + TAB + normalizeCacheField(userName) + TAB + normalizeCacheField(passwordValue) + TAB + normalizeCacheField(sourceText)
  cacheData.lines.push(cacheLine)
  cacheData.records.push({
    "host_public": normalizeCacheField(hostPublic),
    "host_local": normalizeCacheField(hostLocal),
    "user": normalizeCacheField(userName),
    "password": normalizeCacheField(passwordValue),
    "source": normalizeCacheField(sourceText),
  })
  return 1
end function

buildSurfaceCacheKey = function(hostIp, portNumber, libName, libVersion, memoryAddress, unsafeValue, originText)
  return normalizeCacheField(hostIp) + TAB + normalizeCacheField(portNumber) + TAB + normalizeCacheField(libName) + TAB + normalizeCacheField(libVersion) + TAB + normalizeCacheField(memoryAddress) + TAB + normalizeCacheField(unsafeValue) + TAB + normalizeCacheField(originText)
end function

addSurfaceRecord = function(runState, targetRecord, portNumber, libName, libVersion, memoryAddress, unsafeValue, scanInfo = "", originText = "remote")
  if runState == null then return 0
  if not runState.config.surface_report then return 0

  hostIp = ""
  hostPublicIp = ""
  hostLocalIp = ""
  if targetRecord != null then
    hostIp = normalizeInput(targetRecord.ip).trim
    hostPublicIp = normalizeInput(targetRecord.public_ip).trim
    hostLocalIp = normalizeInput(targetRecord.lan_ip).trim
  end if

  recordKey = buildSurfaceCacheKey(hostIp, portNumber, libName, libVersion, memoryAddress, unsafeValue, originText)
  if runState.surface_keys.hasIndex(recordKey) then return 0

  runState.surface_keys[recordKey] = 1
  runState.surface_records.push({
    "host_ip": normalizeCacheField(hostIp),
    "host_public": normalizeCacheField(hostPublicIp),
    "host_local": normalizeCacheField(hostLocalIp),
    "port": normalizeCacheField(portNumber),
    "lib": normalizeCacheField(libName),
    "version": normalizeCacheField(libVersion),
    "memory": normalizeCacheField(memoryAddress),
    "unsafe": normalizeCacheField(unsafeValue),
    "origin": normalizeCacheField(originText),
    "scan_info": normalizeCacheField(scanInfo),
  })
  return 1
end function

saveSurfaceCache = function(surfaceCacheFile, runState)
  if surfaceCacheFile == null then return "Missing surface cache file"

  lines = ["host_ip" + TAB + "host_public" + TAB + "host_local" + TAB + "port" + TAB + "lib" + TAB + "version" + TAB + "memory" + TAB + "unsafe" + TAB + "origin" + TAB + "scan_info"]
  if runState != null and runState.surface_records != null then
    for record in runState.surface_records
      if record == null then continue
      appendLine(lines, record.host_ip + TAB + record.host_public + TAB + record.host_local + TAB + record.port + TAB + record.lib + TAB + record.version + TAB + record.memory + TAB + record.unsafe + TAB + record.origin + TAB + record.scan_info)
    end for
  end if

  return surfaceCacheFile.set_content(lines.join(NL))
end function

buildLootCacheKey = function(hostPublic, hostLocal, userName, artifactType, accountName, sourcePath)
  return normalizeCacheField(hostPublic) + TAB + normalizeCacheField(hostLocal) + TAB + normalizeCacheField(userName) + TAB + normalizeCacheField(artifactType) + TAB + normalizeCacheField(accountName) + TAB + normalizeCacheField(sourcePath)
end function

addLootRecord = function(runState, hostPublic, hostLocal, userName, artifactType, accountName, secretValue, sourcePath, noteText = "")
  if runState == null then return 0
  if not runState.config.loot_mode then return 0

  recordKey = buildLootCacheKey(hostPublic, hostLocal, userName, artifactType, accountName, sourcePath)
  if runState.loot_keys.hasIndex(recordKey) then return 0

  runState.loot_keys[recordKey] = 1
  runState.loot_records.push({
    "host_public": normalizeCacheField(hostPublic),
    "host_local": normalizeCacheField(hostLocal),
    "user": normalizeCacheField(userName),
    "artifact_type": normalizeCacheField(artifactType),
    "account": normalizeCacheField(accountName),
    "secret": normalizeCacheField(secretValue),
    "source": normalizeCacheField(sourcePath),
    "notes": normalizeCacheField(noteText),
  })
  return 1
end function

saveLootCache = function(lootCacheFile, runState)
  if lootCacheFile == null then return "Missing loot cache file"

  lines = ["host_public" + TAB + "host_local" + TAB + "user" + TAB + "artifact_type" + TAB + "account" + TAB + "secret" + TAB + "source" + TAB + "notes"]
  if runState != null and runState.loot_records != null then
    for record in runState.loot_records
      if record == null then continue
      appendLine(lines, record.host_public + TAB + record.host_local + TAB + record.user + TAB + record.artifact_type + TAB + record.account + TAB + record.secret + TAB + record.source + TAB + record.notes)
    end for
  end if

  return lootCacheFile.set_content(lines.join(NL))
end function

buildStageArtifactKey = function(hostKey, pathValue, artifactType)
  return normalizeCacheField(hostKey) + TAB + normalizeCacheField(pathValue) + TAB + normalizeCacheField(artifactType)
end function

addStagedArtifact = function(runState, hostKey, pathValue, artifactType)
  if runState == null then return 0

  artifactKey = buildStageArtifactKey(hostKey, pathValue, artifactType)
  seenField = "stage_artifact_keys"
  if not runState.hasIndex(seenField) then runState[seenField] = {}
  if runState[seenField].hasIndex(artifactKey) then return 0

  runState[seenField][artifactKey] = 1
  runState.staged_paths.push({
    "host_key": normalizeCacheField(hostKey),
    "path": normalizeCacheField(pathValue),
    "type": normalizeCacheField(artifactType),
  })
  return 1
end function

loadPreferredLib = function(fileName, libDir = "")
  builtInLib = include_lib("/lib/" + fileName)
  if builtInLib != null then return builtInLib

  normalizedLibDir = normalizeInput(libDir).trim
  if normalizedLibDir != "" then
    externalLib = include_lib(normalizedLibDir + "/" + fileName)
    if externalLib != null then return externalLib
  end if

  return null
end function

buildRuntimeContext = function(libDir = "")
  shell = get_shell
  if shell == null then exit("Unable to access current shell")

  computer = shell.host_computer
  if computer == null then exit("Unable to access current computer")

  currentRouter = get_router
  meta = loadPreferredLib("metaxploit.so", libDir)
  crypto = loadPreferredLib("crypto.so", libDir)

  return {
    "shell": shell,
    "computer": computer,
    "current_router": currentRouter,
    "program_path": normalizeInput(program_path),
    "current_path": normalizeInput(current_path),
    "home_dir": normalizeInput(home_dir),
    "active_user": normalizeInput(active_user),
    "current_date": normalizeInput(current_date),
    "meta": meta,
    "crypto": crypto,
  }
end function

buildRunConfig = function()
  return {
    "requested_mode": normalizeRunMode(getParamValue("--mode", DEFAULT_MODE), DEFAULT_MODE),
    "mode": DEFAULT_MODE,
    "target_ip": normalizeInput(getParamValue("--target-ip", "")).trim,
    "target_lan_ip": normalizeInput(getParamValue("--target-lan-ip", "")).trim,
    "target_user": normalizeInput(getParamValue("--target-user", "")).trim,
    "shared_dir": normalizeInput(getParamValue("--shared-dir", "")).trim,
    "lib_dir": normalizeInput(getParamValue("--lib-dir", "")).trim,
    "mapper_file": normalizeInput(getParamValue("--mapper-file", "")).trim,
    "non_interactive": getParamFlag("--non-interactive", 0),
    "open_terminal": getParamFlag("--open-terminal", 1),
    "stop_on_success": getParamFlag("--stop-on-success", 1),
    "stage_tools": getParamFlag("--stage-tools", 1),
    "surface_report": getParamFlag("--surface-report", 1),
    "loot_mode": getParamFlag("--loot", 1),
    "manual_assist": getParamFlag("--manual-assist", 0),
    "mission_action": normalizeMissionActionMode(getParamValue("--mission-action", "loot"), "loot"),
    "cleanup_mode": normalizeCleanupMode(getParamValue("--cleanup", "prompt"), "prompt"),
    "pivot_depth": getParamValue("--pivot-depth", "0").val,
    "max_pivot_depth": getParamValue("--max-pivot-depth", "" + DEFAULT_MAX_PIVOT_DEPTH).val,
  }
end function

promptForMissingInputs = function(runConfig)
  if runConfig.non_interactive then return runConfig

  if runConfig.target_ip == "" then
    runConfig.target_ip = normalizeInput(user_input("Target IP / Router IP [blank=current LAN]: ")).trim
  end if

  if runConfig.target_ip != "" and not isValidIpAddress(runConfig.target_ip) then
    exit("Invalid target IP: " + runConfig.target_ip)
  end if

  if runConfig.target_ip != "" and not is_lan_ip(runConfig.target_ip) and runConfig.target_lan_ip == "" then
    runConfig.target_lan_ip = normalizeInput(user_input("Target LAN IP [optional]: ")).trim
  end if

  if runConfig.target_lan_ip != "" and not isValidIpAddress(runConfig.target_lan_ip) then
    exit("Invalid target LAN IP: " + runConfig.target_lan_ip)
  end if

  if runConfig.target_user == "" then
    runConfig.target_user = normalizeInput(user_input("Target username [optional]: ")).trim
  end if

  return runConfig
end function

buildTargetContext = function(runConfig, runtimeContext)
  targetIp = normalizeInput(runConfig.target_ip).trim
  targetLanIp = normalizeInput(runConfig.target_lan_ip).trim
  entryType = "current_lan"
  entryIp = ""
  insideLan = 0
  routerHint = 0
  exactInternalTarget = 0

  if runtimeContext.current_router != null then insideLan = 1

  if targetIp != "" then
    entryIp = targetIp

    if is_lan_ip(targetIp) then
      if isLikelyRouterLanIp(targetIp) then
        entryType = "router_ip"
        routerHint = 1
      else
        entryType = "lan_ip"
      end if
    else
      entryType = "public_ip"
      if targetLanIp != "" then
        routerHint = 1
        exactInternalTarget = 1
      end if
    end if
  else
    if runtimeContext.current_router != null then
      entryIp = normalizeInput(runtimeContext.current_router.local_ip).trim
      entryType = "current_lan"
      routerHint = 1
    else
      entryIp = normalizeInput(runtimeContext.computer.local_ip).trim
    end if
  end if

  if targetLanIp != "" then exactInternalTarget = 1

  return {
    "entry_type": entryType,
    "entry_ip": entryIp,
    "target_ip": targetIp,
    "target_lan_ip": targetLanIp,
    "target_user": normalizeInput(runConfig.target_user).trim,
    "inside_lan": insideLan,
    "router_hint": routerHint,
    "exact_internal_target": exactInternalTarget,
  }
end function

resolveMode = function(runConfig, targetContext)
  requestedMode = normalizeRunMode(runConfig.requested_mode, DEFAULT_MODE)
  if requestedMode != "auto" then return requestedMode

  if targetContext.entry_type == "public_ip" then return "public"
  if targetContext.entry_type == "router_ip" then return "router"
  if targetContext.entry_type == "lan_ip" then return "lan"
  if targetContext.entry_type == "mapped_lan" then return "lan"
  return "lan"
end function

resolveOutputDir = function(runtimeContext, runConfig)
  normalizedSharedDir = normalizeInput(runConfig.shared_dir).trim
  computer = runtimeContext.computer

  if normalizedSharedDir != "" then
    sharedFolder = computer.File(normalizedSharedDir)
    if sharedFolder != null and sharedFolder.is_folder and sharedFolder.has_permission("w") then return normalizedSharedDir
  end if

  outputDir = ensureFolder(computer, runtimeContext.home_dir, DEFAULT_OUTPUT_FOLDER)
  if outputDir == null then outputDir = runtimeContext.home_dir
  return outputDir
end function

prepareOutputFiles = function(runtimeContext, runConfig)
  outputDir = resolveOutputDir(runtimeContext, runConfig)
  if outputDir == null then return null

  reportFile = ensureTextFile(runtimeContext.computer, outputDir, "crs_v1_report.txt")
  hostCacheFile = ensureTextFile(runtimeContext.computer, outputDir, "crs_v1_host_cache.tsv")
  credentialCacheFile = ensureTextFile(runtimeContext.computer, outputDir, "crs_v1_credential_cache.tsv")
  signatureCacheFile = ensureTextFile(runtimeContext.computer, outputDir, "crs_v1_signature_cache.tsv")
  surfaceCacheFile = ensureTextFile(runtimeContext.computer, outputDir, "crs_v1_surface_cache.tsv")
  lootCacheFile = ensureTextFile(runtimeContext.computer, outputDir, "crs_v1_loot_cache.tsv")

  if reportFile == null then return null
  if hostCacheFile == null then return null
  if credentialCacheFile == null then return null
  if signatureCacheFile == null then return null
  if surfaceCacheFile == null then return null
  if lootCacheFile == null then return null

  return {
    "base_dir": outputDir,
    "report_file": reportFile,
    "host_cache_file": hostCacheFile,
    "credential_cache_file": credentialCacheFile,
    "signature_cache_file": signatureCacheFile,
    "surface_cache_file": surfaceCacheFile,
    "loot_cache_file": lootCacheFile,
  }
end function

buildInitialRunState = function(runtimeContext, runConfig, targetContext, outputFiles)
  return {
    "visited_hosts": [],
    "launched_workers": {},
    "pivot_depth": runConfig.pivot_depth,
    "accepted_shell": null,
    "accepted_access_level": "",
    "accepted_host_key": "",
    "provisional_shell": null,
    "provisional_access_level": "",
    "provisional_host_key": "",
    "errors": [],
    "discovered_hosts": [],
    "ranked_hosts": [],
    "selected_host_ip": "",
    "selected_host_record": null,
    "attack_result": null,
    "credential_result": null,
    "handoff_result": null,
    "final_result": null,
    "signature_cache": loadSignatureCache(outputFiles.signature_cache_file),
    "credential_cache": loadCredentialCache(outputFiles.credential_cache_file),
    "credential_attempt_keys": {},
    "surface_records": [],
    "surface_keys": {},
    "loot_records": [],
    "loot_keys": {},
    "staged_toolkit": 0,
    "staged_paths": [],
    "staged_host_keys": {},
    "stage_artifact_keys": {},
    "stage_result": null,
    "loot_result": null,
    "mission_action_result": null,
    "local_recon": null,
    "host_intel": {},
    "preferred_next_host": "",
    "cleanup_result": null,
    "runtime": runtimeContext,
    "config": runConfig,
    "target": targetContext,
    "outputs": outputFiles,
  }
end function

formatValueDisplay = function(value)
  text = normalizeInput(value).trim
  if text == "" then return "-"
  return text
end function

isSameComputer = function(firstComputer, secondComputer)
  if firstComputer == null or secondComputer == null then return 0

  firstPublicIp = normalizeInput(firstComputer.public_ip).trim
  firstLocalIp = normalizeInput(firstComputer.local_ip).trim
  secondPublicIp = normalizeInput(secondComputer.public_ip).trim
  secondLocalIp = normalizeInput(secondComputer.local_ip).trim

  if firstPublicIp != "" and secondPublicIp != "" and firstPublicIp != secondPublicIp then return 0
  if firstLocalIp != "" and secondLocalIp != "" and firstLocalIp != secondLocalIp then return 0
  if firstLocalIp == "" and secondLocalIp == "" then return 0
  if firstPublicIp != "" and secondPublicIp != "" then return 1
  if firstLocalIp != "" and secondLocalIp != "" then return 1
  return 0
end function

computerHasOpenPort = function(remoteComputer, portNumber)
  if remoteComputer == null then return 0

  ports = remoteComputer.get_ports
  if ports == null then return 0

  for portObj in ports
    if portObj == null then continue
    if portObj.is_closed then continue
    if portObj.port_number == portNumber then return 1
  end for

  return 0
end function

buildRemoteLoginAddresses = function(localShell, remoteComputer)
  addresses = []
  seen = []
  if remoteComputer == null then return addresses

  if localShell != null then
    currentComputer = localShell.host_computer
    if currentComputer != null then
      if normalizeInput(currentComputer.public_ip).trim != "" and normalizeInput(currentComputer.public_ip).trim == normalizeInput(remoteComputer.public_ip).trim then
        pushUniqueString(addresses, seen, remoteComputer.local_ip)
      end if
    end if
  end if

  pushUniqueString(addresses, seen, remoteComputer.public_ip)
  pushUniqueString(addresses, seen, remoteComputer.local_ip)
  return addresses
end function

loginAccessType = function(accessObject)
  lowered = normalizeInput(typeof(accessObject)).trim.lower
  if lowered == "shell" then return "shell"
  if lowered.indexOf("ftp") != null then return "ftp"
  return lowered
end function

isTerminalAccessType = function(accessType)
  lowered = normalizeInput(accessType).trim.lower
  if lowered == "shell" then return 1
  return 0
end function

isCredentialAccessType = function(accessType)
  lowered = normalizeInput(accessType).trim.lower
  if lowered == "shell" then return 1
  if lowered == "ftp" then return 1
  return 0
end function

classifyComputerAccessLevel = function(remoteComputer, targetUser = "")
  if remoteComputer == null then return "none"

  shadowFile = remoteComputer.File("/etc/shadow")
  if shadowFile != null and not shadowFile.is_folder and shadowFile.has_permission("r") then return "root"

  rootFolder = remoteComputer.File("/root")
  if rootFolder != null and rootFolder.is_folder and rootFolder.has_permission("r") then return "root"

  readableUsers = listReadableUserHomes(remoteComputer)
  if readableUsers == null or readableUsers.len == 0 then return "guest"

  normalizedTargetUser = normalizeInput(targetUser).trim
  if normalizedTargetUser != "" and listHasValue(readableUsers, normalizedTargetUser) then return "user"

  for readableUser in readableUsers
    if normalizeInput(readableUser).trim.lower != "guest" then return "user"
  end for

  return "guest"
end function

classifyTerminalAccessLevel = function(accessObject, targetUser = "")
  remoteComputer = getAccessHostComputer(accessObject)
  return classifyComputerAccessLevel(remoteComputer, targetUser)
end function

accessLevelScore = function(accessLevel)
  lowered = normalizeInput(accessLevel).trim.lower
  if lowered == "root" then return 3
  if lowered == "user" then return 2
  if lowered == "guest" then return 1
  return 0
end function

recordAcceptedTerminalAccess = function(accessObject, targetRecord, runState)
  accessType = loginAccessType(accessObject)
  if not isTerminalAccessType(accessType) then return 0

  accessLevel = classifyTerminalAccessLevel(accessObject, runState.target.target_user)
  hostKey = buildHostKey(targetRecord.public_ip, targetRecord.lan_ip)
  roleText = normalizeInput(targetRecord.role).trim.lower

  if accessLevel == "guest" and roleText.indexOf("gateway") == null then
    runState.provisional_shell = accessObject
    runState.provisional_access_level = accessLevel
    runState.provisional_host_key = hostKey
    return 0
  end if

  runState.accepted_shell = accessObject
  runState.accepted_access_level = accessLevel
  runState.accepted_host_key = hostKey
  return 1
end function

hasAcceptedNonGuestShell = function(runState)
  if runState == null then return 0
  if runState.accepted_shell == null then return 0

  accessLevel = normalizeInput(runState.accepted_access_level).trim.lower
  if accessLevel == "" then return 1
  if accessLevel == "guest" then return 0
  return 1
end function

tryCredentialServiceAccess = function(sourceShell, remoteComputer, userName, passwordValue, portNumber, serviceType = "")
  if sourceShell == null then return null
  if remoteComputer == null then return null

  for address in buildRemoteLoginAddresses(sourceShell, remoteComputer)
    if serviceType == "" then
      connection = sourceShell.connect_service(address, portNumber, userName, passwordValue)
    else
      connection = sourceShell.connect_service(address, portNumber, userName, passwordValue, serviceType)
    end if

    if connection == null then continue
    if not isCredentialAccessType(loginAccessType(connection)) then continue
    if isSameComputer(connection.host_computer, remoteComputer) then return connection
  end for

  return null
end function

getCredentialShellForComputer = function(localShell, remoteComputer, userName, passwordValue)
  if remoteComputer == null then return null

  localComputer = null
  if localShell != null then localComputer = localShell.host_computer
  if localComputer != null and isSameComputer(localComputer, remoteComputer) then
    loginShell = get_shell(userName, passwordValue)
    if loginShell != null and isSameComputer(loginShell.host_computer, remoteComputer) then return loginShell
  end if

  shouldTrySsh = 1
  remotePorts = remoteComputer.get_ports
  if remotePorts != null and not computerHasOpenPort(remoteComputer, 22) then shouldTrySsh = 0

  if shouldTrySsh then
    sshConnection = tryCredentialServiceAccess(localShell, remoteComputer, userName, passwordValue, 22, "ssh")
    if sshConnection != null then return sshConnection
  end if

  return null
end function

attemptComputerShellEscalation = function(localShell, remoteComputer, targetRecord, runState)
  outcome = {
    "status": "not-attempted",
    "shell": null,
    "access_type": "",
    "user": "",
    "notes": [],
  }

  if localShell == null then
    outcome.status = "missing-local-shell"
    return outcome
  end if

  if remoteComputer == null then
    outcome.status = "missing-computer"
    return outcome
  end if

  appendLine(outcome.notes, "Computer access obtained; attempting shell escalation.")

  changeResult = remoteComputer.change_password(DEFAULT_ROOT_BOOTSTRAP_USER, DEFAULT_ROOT_BOOTSTRAP_PASSWORD)
  if isApiSuccess(changeResult) then
    outcome.status = "root-password-changed"
    outcome.user = DEFAULT_ROOT_BOOTSTRAP_USER
    appendLine(outcome.notes, "Root password changed to configured bootstrap password.")

    loginShell = getCredentialShellForComputer(localShell, remoteComputer, DEFAULT_ROOT_BOOTSTRAP_USER, DEFAULT_ROOT_BOOTSTRAP_PASSWORD)
    if loginShell != null then
      outcome.shell = loginShell
      outcome.access_type = loginAccessType(loginShell)
      if outcome.access_type == "shell" then
        outcome.status = "root-shell"
      else
        outcome.status = outcome.access_type + "-shell"
      end if
      addCredentialCacheRecord(runState.credential_cache, remoteComputer.public_ip, remoteComputer.local_ip, DEFAULT_ROOT_BOOTSTRAP_USER, DEFAULT_ROOT_BOOTSTRAP_PASSWORD, "computer-escalation")
      recordAcceptedTerminalAccess(loginShell, targetRecord, runState)
      appendLine(outcome.notes, "Shell login succeeded with root bootstrap credentials.")
      return outcome
    end if

    appendLine(outcome.notes, "Root password changed, but shell login failed.")
  else
    appendLine(outcome.notes, "Root password change failed: " + normalizeInput(changeResult))
  end if

  createResult = remoteComputer.create_user(DEFAULT_PERSISTENCE_BOOTSTRAP_USER, DEFAULT_PERSISTENCE_BOOTSTRAP_PASSWORD)
  if not isApiSuccess(createResult) then
    changePersistenceResult = remoteComputer.change_password(DEFAULT_PERSISTENCE_BOOTSTRAP_USER, DEFAULT_PERSISTENCE_BOOTSTRAP_PASSWORD)
    if not isApiSuccess(changePersistenceResult) then
      outcome.status = "no-shell"
      appendLine(outcome.notes, "Persistence bootstrap failed: create_user=" + normalizeInput(createResult) + " / change_password=" + normalizeInput(changePersistenceResult))
      return outcome
    end if

    outcome.status = "persistence-password-changed"
    outcome.user = DEFAULT_PERSISTENCE_BOOTSTRAP_USER
    appendLine(outcome.notes, "Existing persistence user password changed to configured bootstrap password.")
  else
    outcome.status = "persistence-user-created"
    outcome.user = DEFAULT_PERSISTENCE_BOOTSTRAP_USER
    appendLine(outcome.notes, "Persistence user created with configured bootstrap password.")
  end if

  persistenceShell = getCredentialShellForComputer(localShell, remoteComputer, DEFAULT_PERSISTENCE_BOOTSTRAP_USER, DEFAULT_PERSISTENCE_BOOTSTRAP_PASSWORD)
  if persistenceShell == null then
    outcome.status = "no-shell"
    appendLine(outcome.notes, "Persistence credentials prepared, but shell login failed.")
    return outcome
  end if

  outcome.shell = persistenceShell
  outcome.access_type = loginAccessType(persistenceShell)
  if outcome.access_type == "shell" then
    outcome.status = "persistence-shell"
  else
    outcome.status = outcome.access_type + "-shell"
  end if
  addCredentialCacheRecord(runState.credential_cache, remoteComputer.public_ip, remoteComputer.local_ip, DEFAULT_PERSISTENCE_BOOTSTRAP_USER, DEFAULT_PERSISTENCE_BOOTSTRAP_PASSWORD, "computer-escalation")
  recordAcceptedTerminalAccess(persistenceShell, targetRecord, runState)
  appendLine(outcome.notes, "Shell login succeeded with persistence credentials.")
  return outcome
end function

pathBaseName = function(pathValue)
  pathText = normalizeInput(pathValue).trim
  if pathText == "" then return ""

  parts = pathText.split("/")
  if parts == null or parts.len == 0 then return pathText

  lastPart = parts[parts.len - 1]
  if lastPart != "" then return lastPart
  if parts.len > 1 then return parts[parts.len - 2]
  return pathText
end function

containsCredentialKeyword = function(textValue)
  lowered = normalizeInput(textValue).trim.lower
  if lowered == "" then return 0

  for keyword in CREDENTIAL_KEYWORDS
    if lowered.indexOf(keyword) != null then return 1
  end for

  return 0
end function

isTokenChar = function(ch)
  if ch == null or ch == "" then return 0
  return TOKEN_CHARS.indexOf(ch) != null
end function

extractTokens = function(textValue, minLen = 3)
  tokens = []
  current = ""

  for ch in normalizeText(textValue)
    if isTokenChar(ch) then
      current = current + ch
    else
      if current.len >= minLen then tokens.push(current)
      current = ""
    end if
  end for

  if current.len >= minLen then tokens.push(current)
  return tokens
end function

listReadableUserHomes = function(remoteComputer)
  users = []
  homeFolder = remoteComputer.File("/home")
  if homeFolder == null then return users
  if not homeFolder.is_folder then return users
  if not homeFolder.has_permission("r") then return users

  subFolders = homeFolder.get_folders
  if subFolders == null then return users

  for subFolder in subFolders
    if subFolder == null then continue
    if not subFolder.is_folder then continue
    if not subFolder.has_permission("r") then continue
    users.push(pathBaseName(subFolder.path))
  end for

  return users
end function

collectCredentialUsers = function(remoteComputer, targetUser = "", runtimeContext = null)
  users = []
  seen = []

  pushUniqueString(users, seen, DEFAULT_ROOT_BOOTSTRAP_USER)
  if targetUser != "" then pushUniqueString(users, seen, targetUser)
  if runtimeContext != null and runtimeContext.computer != null and isSameComputer(runtimeContext.computer, remoteComputer) then
    activeUserText = normalizeInput(runtimeContext.active_user).trim
    if activeUserText != "" then pushUniqueString(users, seen, activeUserText)
  end if

  passwdFile = remoteComputer.File("/etc/passwd")
  passwdContent = readTextFile(passwdFile)
  if passwdContent != null and passwdContent != "" then
    for line in passwdContent.split(NL)
      cleanLine = normalizeInput(line).trim
      if cleanLine == "" then continue
      parts = cleanLine.split(":")
      if parts == null or parts.len == 0 then continue
      pushUniqueString(users, seen, parts[0])
    end for
  end if

  for userName in listReadableUserHomes(remoteComputer)
    pushUniqueString(users, seen, userName)
  end for

  return users
end function

pushPotentialUserName = function(users, seen, rawValue)
  candidateValue = normalizeText(rawValue).trim
  if candidateValue == "" then return 0

  if candidateValue.indexOf("@") != null then candidateValue = candidateValue.split("@")[0]
  if candidateValue.indexOf(" ") != null then candidateValue = candidateValue.split(" ")[0]
  if candidateValue.indexOf(":") != null then candidateValue = candidateValue.split(":")[0]

  candidateValue = normalizeText(candidateValue).trim
  if candidateValue == "" then return 0
  return pushUniqueString(users, seen, candidateValue)
end function

collectSmtpEnumeratedUsers = function(crypto, localShell, remoteComputer, users, notes = null)
  if crypto == null then return 0
  if remoteComputer == null then return 0
  if not computerHasOpenPort(remoteComputer, 25) then return 0

  addresses = buildRemoteLoginAddresses(localShell, remoteComputer)
  if addresses == null or addresses.len == 0 then return 0

  seen = []
  for existingUser in users
    cleanUser = normalizeInput(existingUser).trim
    if cleanUser == "" then continue
    if listHasValue(seen, cleanUser) then continue
    seen.push(cleanUser)
  end for

  added = 0
  for address in addresses
    if address == "" then continue

    smtpUsers = crypto.smtp_user_list(address, 25)
    if smtpUsers == null then continue
    if smtpUsers isa string then
      if notes != null and normalizeInput(smtpUsers).trim != "" then appendLine(notes, "SMTP enumeration note on " + address + ": " + normalizeInput(smtpUsers).trim)
      continue
    end if

    for smtpUser in smtpUsers
      added = added + pushPotentialUserName(users, seen, smtpUser)
    end for

    if notes != null and smtpUsers.len > 0 then appendLine(notes, "SMTP users discovered on " + address + ": " + smtpUsers.len)
  end for

  return added
end function

resolveStructuredSecret = function(crypto, rawValue)
  secretText = normalizeText(rawValue).trim
  if secretText == "" then return ""
  if crypto == null then return secretText

  deciphered = crypto.decipher(secretText)
  decipheredText = normalizeText(deciphered).trim
  if decipheredText != "" and decipheredText != secretText then return decipheredText
  return secretText
end function

addStructuredLootFromHostHints = function(runtimeContext, runState, hostPublicIp, hostLocalIp, file, fallbackUser = "", artifactType = "file")
  added = 0
  if runtimeContext == null or runState == null then return added
  content = readTextFile(file)
  if content == null or content == "" then return added

  firstLine = ""
  for line in content.split(NL)
    firstLine = normalizeText(line).trim
    if firstLine != "" then break
  end for
  if firstLine == "" then return added

  parts = firstLine.split(":")
  if parts == null or parts.len < 2 then return added

  accountName = normalizeText(parts[0]).trim
  if accountName == "" then accountName = fallbackUser
  secretValue = resolveStructuredSecret(runtimeContext.crypto, parts[1])
  if accountName == "" and secretValue == "" then return added

  added = added + addLootRecord(runState, hostPublicIp, hostLocalIp, fallbackUser, artifactType, accountName, secretValue, file.path)
  return added
end function

addStructuredLootFromFile = function(runtimeContext, runState, remoteComputer, file, fallbackUser = "", artifactType = "file")
  if remoteComputer == null then return 0
  return addStructuredLootFromHostHints(runtimeContext, runState, remoteComputer.public_ip, remoteComputer.local_ip, file, fallbackUser, artifactType)
end function

addPasswdLootFromFile = function(runtimeContext, runState, hostPublicIp, hostLocalIp, passwdFile, sourceText = "passwd-file")
  outcome = {
    "added": 0,
    "credential_records": 0,
    "users": 0,
  }

  if runtimeContext == null or runState == null then return outcome

  passwdContent = readTextFile(passwdFile)
  if passwdContent == null or passwdContent == "" then return outcome

  for line in passwdContent.split(NL)
    userLine = normalizeText(line).trim
    if userLine == "" then continue
    userParts = userLine.split(":")
    if userParts == null or userParts.len < 2 then continue

    userName = normalizeText(userParts[0]).trim
    if userName == "" then continue

    secretValue = resolveStructuredSecret(runtimeContext.crypto, userParts[1])
    if addLootRecord(runState, hostPublicIp, hostLocalIp, userName, "passwd", userName, secretValue, passwdFile.path) then
      outcome.added = outcome.added + 1
    end if

    if secretValue != "" and secretValue.len >= 3 then
      if addCredentialCacheRecord(runState.credential_cache, hostPublicIp, hostLocalIp, userName, secretValue, sourceText) then
        outcome.credential_records = outcome.credential_records + 1
      end if
    end if

    outcome.users = outcome.users + 1
  end for

  return outcome
end function

collectStructuredLoot = function(runtimeContext, remoteComputer, targetContext, runState)
  outcome = {
    "status": "not-run",
    "records": [],
    "scanned_files": 0,
    "added": 0,
    "notes": [],
  }

  if runtimeContext == null or runState == null then
    outcome.status = "missing-state"
    return outcome
  end if

  if not runState.config.loot_mode then
    outcome.status = "disabled"
    return outcome
  end if

  if remoteComputer == null then
    outcome.status = "missing-computer"
    return outcome
  end if

  passwdFile = remoteComputer.File("/etc/passwd")
  passwdOutcome = addPasswdLootFromFile(runtimeContext, runState, remoteComputer.public_ip, remoteComputer.local_ip, passwdFile, "structured-loot-passwd")
  if passwdOutcome.users > 0 then
    outcome.scanned_files = outcome.scanned_files + 1
    outcome.added = outcome.added + passwdOutcome.added
  end if

  homeFolder = remoteComputer.File("/home")
  if homeFolder != null and homeFolder.is_folder and homeFolder.has_permission("r") then
    for userFolder in homeFolder.get_folders
      yield
      if userFolder == null then continue
      if not userFolder.is_folder then continue

      userName = normalizeText(userFolder.name).trim
      if targetContext != null and normalizeInput(targetContext.target_user).trim != "" then
        if userName.lower != normalizeInput(targetContext.target_user).trim.lower and userName.lower != "guest" then
          // Keep the target user and guest by default when a specific user was requested.
          continue
        end if
      end if

      for artifact in [{"type":"mail", "path":"/home/" + userName + "/Config/Mail.txt"}, {"type":"bank", "path":"/home/" + userName + "/Config/Bank.txt"}]
        file = remoteComputer.File(artifact.path)
        if file == null then continue
        outcome.scanned_files = outcome.scanned_files + 1
        outcome.added = outcome.added + addStructuredLootFromFile(runtimeContext, runState, remoteComputer, file, userName, artifact.type)
      end for
    end for
  end if

  for lootRecord in runState.loot_records
    if lootRecord == null then continue
    if normalizeInput(lootRecord.host_public).trim != normalizeInput(remoteComputer.public_ip).trim then continue
    if normalizeInput(lootRecord.host_local).trim != normalizeInput(remoteComputer.local_ip).trim then continue
    outcome.records.push(lootRecord)
  end for

  outcome.status = "complete"
  appendLine(outcome.notes, "Structured loot records: " + outcome.records.len)
  appendLine(outcome.notes, "Structured loot files scanned: " + outcome.scanned_files)
  return outcome
end function

lootRecordMatchesMissionAction = function(lootRecord, missionActionMode)
  if lootRecord == null then return 0
  actionMode = normalizeMissionActionMode(missionActionMode, "loot")
  if actionMode == "off" then return 0
  if actionMode == "loot" or actionMode == "all" then return 1
  return normalizeInput(lootRecord.artifact_type).trim.lower == actionMode
end function

collectMissionLootRecords = function(runState, remoteComputer, missionActionMode)
  records = []
  if runState == null then return records
  if remoteComputer == null then return records
  if runState.loot_records == null then return records

  remotePublicIp = normalizeInput(remoteComputer.public_ip).trim
  remoteLocalIp = normalizeInput(remoteComputer.local_ip).trim

  for lootRecord in runState.loot_records
    if lootRecord == null then continue
    if normalizeInput(lootRecord.host_public).trim != remotePublicIp then continue
    if normalizeInput(lootRecord.host_local).trim != remoteLocalIp then continue
    if not lootRecordMatchesMissionAction(lootRecord, missionActionMode) then continue
    records.push(lootRecord)
  end for

  return records
end function

pushPasswordCandidate = function(candidates, seen, rawValue, sourceText)
  candidateValue = normalizeText(rawValue).trim
  if candidateValue == "" then return 0
  if candidateValue.len < 3 then return 0
  if candidateValue.len > 64 then return 0
  if listHasValue(seen, candidateValue) then return 0

  seen.push(candidateValue)
  candidates.push({
    "value": candidateValue,
    "source": normalizeInput(sourceText).trim,
  })
  return 1
end function

addPasswordCandidateVariants = function(crypto, candidates, seen, rawValue, sourceText)
  added = pushPasswordCandidate(candidates, seen, rawValue, sourceText)

  if crypto == null then return added

  deciphered = crypto.decipher(normalizeText(rawValue).trim)
  decipheredText = normalizeText(deciphered).trim
  if decipheredText != "" and decipheredText != normalizeText(rawValue).trim then
    added = added + pushPasswordCandidate(candidates, seen, decipheredText, sourceText + " [decipher]")
  end if

  return added
end function

collectPasswordCandidatesFromLine = function(crypto, candidates, seen, lineText, sourceText, targetUser = "", maxCandidates = MAX_CREDENTIAL_CANDIDATES)
  if candidates.len >= maxCandidates then return 0

  normalizedLine = normalizeText(lineText).trim
  if normalizedLine == "" then return 0

  lineLower = normalizedLine.lower
  sourceLower = normalizeInput(sourceText).trim.lower
  interested = containsCredentialKeyword(sourceLower) or containsCredentialKeyword(lineLower) or sourceLower.indexOf("passwd") != null or sourceLower.indexOf("shadow") != null
  if targetUser != "" and lineLower.indexOf(targetUser.lower) != null then interested = 1
  if not interested and normalizedLine.indexOf(":") == null then return 0

  added = 0
  fields = normalizedLine.split(":")
  fieldIndex = 0
  if fields != null and fields.len > 1 then
    for field in fields
      if candidates.len >= maxCandidates then return added

      fieldIndex = fieldIndex + 1
      fieldValue = normalizeInput(field).trim
      if fieldValue == "" then continue
      if fieldIndex == 1 then continue
      added = added + addPasswordCandidateVariants(crypto, candidates, seen, fieldValue, sourceText + " [field " + fieldIndex + "]")
    end for
  end if

  for token in extractTokens(normalizedLine, 4)
    if candidates.len >= maxCandidates then return added
    added = added + addPasswordCandidateVariants(crypto, candidates, seen, token, sourceText + " [token]")
  end for

  return added
end function

collectPasswordCandidatesFromFile = function(crypto, file, candidates, seen, targetUser = "", maxLines = MAX_CREDENTIAL_LINES, maxCandidates = MAX_CREDENTIAL_CANDIDATES)
  content = readTextFile(file)
  if content == null or content == "" then return 0

  added = 0
  lineNumber = 1
  for line in content.split(NL)
    if lineNumber > maxLines then break
    if candidates.len >= maxCandidates then return added

    added = added + collectPasswordCandidatesFromLine(crypto, candidates, seen, line, file.path + " [line " + lineNumber + "]", targetUser, maxCandidates)
    lineNumber = lineNumber + 1
  end for

  return added
end function

collectPasswordCandidatesFromFolder = function(crypto, folder, candidates, seen, targetUser, stats, depth = 0, maxDepth = 2)
  if folder == null then return
  if not folder.is_folder then return
  if not folder.has_permission("r") then return
  if depth > maxDepth then return
  if stats.scanned_files >= stats.max_files then return
  if candidates.len >= stats.max_candidates then return

  files = folder.get_files
  if files != null then
    for file in files
      yield
      if stats.scanned_files >= stats.max_files then return
      if candidates.len >= stats.max_candidates then return
      if file == null then continue

      stats.scanned_files = stats.scanned_files + 1
      stats.added = stats.added + collectPasswordCandidatesFromFile(crypto, file, candidates, seen, targetUser, stats.max_lines, stats.max_candidates)
    end for
  end if

  subFolders = folder.get_folders
  if subFolders == null then return

  for subFolder in subFolders
    yield
    if stats.scanned_files >= stats.max_files then return
    if candidates.len >= stats.max_candidates then return
    collectPasswordCandidatesFromFolder(crypto, subFolder, candidates, seen, targetUser, stats, depth + 1, maxDepth)
  end for
end function

collectCredentialIntel = function(runtimeContext, remoteComputer, targetContext, runState = null)
  intelBundle = {
    "users": [],
    "password_candidates": [],
    "scanned_files": 0,
    "loot_records": [],
    "notes": [],
  }

  if remoteComputer == null then
    appendLine(intelBundle.notes, "Credential intel skipped: missing remote computer.")
    return intelBundle
  end if

  intelBundle.users = collectCredentialUsers(remoteComputer, targetContext.target_user, runtimeContext)
  collectSmtpEnumeratedUsers(runtimeContext.crypto, runtimeContext.shell, remoteComputer, intelBundle.users, intelBundle.notes)
  candidateSeen = []
  stats = {
    "scanned_files": 0,
    "added": 0,
    "max_files": MAX_CREDENTIAL_FILES,
    "max_lines": MAX_CREDENTIAL_LINES,
    "max_candidates": MAX_CREDENTIAL_CANDIDATES,
  }

  stats.added = stats.added + collectPasswordCandidatesFromFile(runtimeContext.crypto, remoteComputer.File("/etc/passwd"), intelBundle.password_candidates, candidateSeen, targetContext.target_user, stats.max_lines, stats.max_candidates)
  stats.added = stats.added + collectPasswordCandidatesFromFile(runtimeContext.crypto, remoteComputer.File("/etc/shadow"), intelBundle.password_candidates, candidateSeen, targetContext.target_user, stats.max_lines, stats.max_candidates)
  collectPasswordCandidatesFromFolder(runtimeContext.crypto, remoteComputer.File("/etc"), intelBundle.password_candidates, candidateSeen, targetContext.target_user, stats, 0, 1)

  if targetContext.target_user != "" then
    collectPasswordCandidatesFromFolder(runtimeContext.crypto, remoteComputer.File("/home/" + targetContext.target_user), intelBundle.password_candidates, candidateSeen, targetContext.target_user, stats, 0, 2)
  else
    collectPasswordCandidatesFromFolder(runtimeContext.crypto, remoteComputer.File("/home"), intelBundle.password_candidates, candidateSeen, targetContext.target_user, stats, 0, 1)
  end if

  intelBundle.scanned_files = stats.scanned_files
  lootBundle = collectStructuredLoot(runtimeContext, remoteComputer, targetContext, runState)
  intelBundle.loot_records = lootBundle.records
  if lootBundle.records != null then
    for lootRecord in lootBundle.records
      if lootRecord == null then continue
      addPasswordCandidateVariants(runtimeContext.crypto, intelBundle.password_candidates, candidateSeen, lootRecord.secret, lootRecord.source + " [loot]")
    end for
  end if
  intelBundle.scanned_files = intelBundle.scanned_files + lootBundle.scanned_files
  for noteLine in lootBundle.notes
    appendLine(intelBundle.notes, noteLine)
  end for
  appendLine(intelBundle.notes, "Credential users discovered: " + intelBundle.users.len)
  appendLine(intelBundle.notes, "Credential password candidates: " + intelBundle.password_candidates.len)
  appendLine(intelBundle.notes, "Credential files scanned: " + intelBundle.scanned_files)
  return intelBundle
end function

getAttackResultComputer = function(attackResult)
  if attackResult == null then return null
  if attackResult.result == null then return null

  resultType = normalizeInput(attackResult.result_type).trim.lower
  if resultType == "computer" then return attackResult.result
  if resultType == "shell" or resultType == "ftp" then return attackResult.result.host_computer
  return null
end function

hostRecordHasPort = function(hostRecord, portNumber)
  if hostRecord == null then return 0
  if hostRecord.open_ports == null then return 0

  for portInfo in hostRecord.open_ports
    if portInfo == null then continue
    if portInfo.port == portNumber then return 1
  end for

  return 0
end function

buildHostRecordLoginAddresses = function(localShell, hostRecord)
  addresses = []
  seen = []
  if hostRecord == null then return addresses

  if localShell != null then
    currentComputer = localShell.host_computer
    if currentComputer != null then
      currentPublicIp = normalizeInput(currentComputer.public_ip).trim
      targetPublicIp = normalizeInput(hostRecord.public_ip).trim
      targetLanIp = normalizeInput(hostRecord.lan_ip).trim
      if currentPublicIp != "" and targetPublicIp != "" and currentPublicIp == targetPublicIp and targetLanIp != "" then
        pushUniqueString(addresses, seen, targetLanIp)
      end if
    end if
  end if

  pushUniqueString(addresses, seen, hostRecord.ip)
  pushUniqueString(addresses, seen, hostRecord.public_ip)
  pushUniqueString(addresses, seen, hostRecord.lan_ip)
  return addresses
end function

buildCredentialReuseTargets = function(rankedHosts, selectedHostRecord, sourceComputer = null)
  targets = []
  seen = []
  referencePublicIp = ""
  referenceGatewayIp = ""

  if selectedHostRecord != null then
    addUniqueHostRecord(targets, seen, selectedHostRecord)
    referencePublicIp = normalizeInput(selectedHostRecord.public_ip).trim
    referenceGatewayIp = normalizeInput(selectedHostRecord.gateway_ip).trim
  end if

  if sourceComputer != null then
    if referencePublicIp == "" then referencePublicIp = normalizeInput(sourceComputer.public_ip).trim
  end if

  if rankedHosts == null then return targets

  for hostRecord in rankedHosts
    if hostRecord == null then continue

    if referencePublicIp != "" then
      hostPublicIp = normalizeInput(hostRecord.public_ip).trim
      if hostPublicIp != "" and hostPublicIp != referencePublicIp then continue
    end if

    if referenceGatewayIp != "" then
      hostGatewayIp = normalizeInput(hostRecord.gateway_ip).trim
      hostIp = normalizeInput(hostRecord.ip).trim
      if hostGatewayIp != "" and hostGatewayIp != referenceGatewayIp and hostIp != referenceGatewayIp then continue
    end if

    addUniqueHostRecord(targets, seen, hostRecord)
  end for

  return targets
end function

buildCredentialUserOrder = function(users, targetUser = "")
  ordered = []
  seen = []

  pushUniqueString(ordered, seen, DEFAULT_ROOT_BOOTSTRAP_USER)
  if targetUser != "" then pushUniqueString(ordered, seen, targetUser)

  if users != null then
    for userName in users
      pushUniqueString(ordered, seen, userName)
    end for
  end if

  return ordered
end function

credentialCacheScopeScore = function(cacheRecord, hostRecord)
  if cacheRecord == null then return 0
  if hostRecord == null then return 0

  cachePublicIp = normalizeInput(cacheRecord.host_public).trim
  cacheLocalIp = normalizeInput(cacheRecord.host_local).trim
  hostPublicIp = normalizeInput(hostRecord.public_ip).trim
  hostLocalIp = normalizeInput(hostRecord.lan_ip).trim
  if hostLocalIp == "" and is_lan_ip(hostRecord.ip) then hostLocalIp = normalizeInput(hostRecord.ip).trim

  if cacheLocalIp != "" and hostLocalIp != "" and cacheLocalIp == hostLocalIp then return 2
  if cachePublicIp != "" and hostPublicIp != "" and cachePublicIp == hostPublicIp then return 1
  return 0
end function

buildScopedCredentialCacheRecords = function(cacheData, hostRecord)
  exactMatches = []
  chainMatches = []
  if cacheData == null or cacheData.records == null then return chainMatches
  if hostRecord == null then return chainMatches

  for cacheRecord in cacheData.records
    if cacheRecord == null then continue

    scopeScore = credentialCacheScopeScore(cacheRecord, hostRecord)
    if scopeScore >= 1 then chainMatches.push(cacheRecord)
    if scopeScore >= 2 then exactMatches.push(cacheRecord)
  end for

  if exactMatches.len > 0 then return exactMatches
  return chainMatches
end function

tryCredentialHostRecordAccess = function(localShell, hostRecord, userName, passwordValue)
  if localShell == null then return null
  if hostRecord == null then return null

  addresses = buildHostRecordLoginAddresses(localShell, hostRecord)
  if addresses == null or addresses.len == 0 then return null

  if hostRecordHasPort(hostRecord, 22) then
    for address in addresses
      connection = localShell.connect_service(address, 22, userName, passwordValue, "ssh")
      if connection == null then continue
      if isTerminalAccessType(loginAccessType(connection)) then return connection
    end for
  end if

  return null
end function

attemptCredentialReuse = function(runtimeContext, runState, attackResult)
  outcome = {
    "status": "not-run",
    "shell": null,
    "host_ip": "",
    "user": "",
    "source_host": "",
    "attempts": 0,
    "successes": 0,
    "scanned_files": 0,
    "password_candidates": 0,
    "loot_records": 0,
    "notes": [],
  }

  if hasAcceptedNonGuestShell(runState) then
    outcome.status = "skipped-existing-shell"
    appendLine(outcome.notes, "Credential reuse skipped because an accepted non-guest shell is already available.")
    return outcome
  end if

  sourceComputer = getAttackResultComputer(attackResult)
  if sourceComputer != null then
    outcome.source_host = formatValueDisplay(sourceComputer.public_ip) + " / " + formatValueDisplay(sourceComputer.local_ip)
  end if

  targets = buildCredentialReuseTargets(runState.ranked_hosts, runState.selected_host_record, sourceComputer)
  exactTargetRecord = findExactTargetHostRecord(runState.ranked_hosts, runState.target)
  sourceHostRecord = findHostRecordForComputer(runState.ranked_hosts, sourceComputer)
  if exactTargetRecord != null and sourceHostRecord != null then
    if normalizeInput(sourceHostRecord.ip).trim == normalizeInput(exactTargetRecord.ip).trim then
      targets = [exactTargetRecord]
      appendLine(outcome.notes, "Exact target foothold obtained; restricting credential reuse to same host.")
    end if
  end if
  if targets.len == 0 then
    outcome.status = "no-targets"
    return outcome
  end if

  intelBundle = {
    "users": [],
    "password_candidates": [],
    "scanned_files": 0,
    "notes": [],
  }
  if sourceComputer != null then
    intelBundle = collectCredentialIntel(runtimeContext, sourceComputer, runState.target, runState)
    outcome.scanned_files = intelBundle.scanned_files
    outcome.password_candidates = intelBundle.password_candidates.len
    outcome.loot_records = intelBundle.loot_records.len
    for noteLine in intelBundle.notes
      appendLine(outcome.notes, noteLine)
    end for
  end if

  cachedCredentialCount = 0
  if runState.credential_cache != null and runState.credential_cache.records != null then cachedCredentialCount = runState.credential_cache.records.len

  if cachedCredentialCount == 0 and intelBundle.password_candidates.len == 0 then
    outcome.status = "no-credentials"
    appendLine(outcome.notes, "No cached or discovered credentials available.")
    return outcome
  end if

  orderedUsers = buildCredentialUserOrder(intelBundle.users, runState.target.target_user)

  for hostRecord in targets
    yield
    if hostRecord == null then continue
    if not hostRecordHasPort(hostRecord, 22) then continue

    scopedCacheRecords = buildScopedCredentialCacheRecords(runState.credential_cache, hostRecord)

    for priorityPass in [0, 1, 2]
      for cacheRecord in scopedCacheRecords
        yield
        if cacheRecord == null then continue

        cacheUser = normalizeInput(cacheRecord.user).trim
        targetUser = normalizeInput(runState.target.target_user).trim.lower
        if priorityPass == 0 and cacheUser.lower != DEFAULT_ROOT_BOOTSTRAP_USER then continue
        if priorityPass == 1 and (targetUser == "" or targetUser == DEFAULT_ROOT_BOOTSTRAP_USER or cacheUser.lower != targetUser) then continue
        if priorityPass == 2 then
          if cacheUser.lower == DEFAULT_ROOT_BOOTSTRAP_USER then continue
          if targetUser != "" and cacheUser.lower == targetUser then continue
        end if

        attemptKey = normalizeInput(hostRecord.ip).trim + TAB + cacheUser + TAB + normalizeInput(cacheRecord.password).trim
        if runState.credential_attempt_keys.hasIndex(attemptKey) then continue
        if outcome.attempts >= MAX_CREDENTIAL_ATTEMPTS then
          outcome.status = "attempt-limit"
          appendLine(outcome.notes, "Credential attempt limit reached while replaying cached credentials.")
          return outcome
        end if

        runState.credential_attempt_keys[attemptKey] = 1
        outcome.attempts = outcome.attempts + 1
        connection = tryCredentialHostRecordAccess(runtimeContext.shell, hostRecord, cacheUser, cacheRecord.password)
        if connection == null then continue

        outcome.successes = outcome.successes + 1
        outcome.status = "cache-success"
        outcome.shell = connection
        outcome.host_ip = hostRecord.ip
        outcome.user = cacheUser
        recordAcceptedTerminalAccess(connection, hostRecord, runState)
        appendLine(outcome.notes, "Cached credential success: " + cacheUser + " @ " + hostRecord.ip)
        addCredentialCacheRecord(runState.credential_cache, hostRecord.public_ip, hostRecord.lan_ip, cacheUser, cacheRecord.password, "cache-replay")
        return outcome
      end for
    end for

    for userName in orderedUsers
      for candidate in intelBundle.password_candidates
        yield
        if candidate == null then continue
        if outcome.attempts >= MAX_CREDENTIAL_ATTEMPTS then
          outcome.status = "attempt-limit"
          appendLine(outcome.notes, "Credential attempt limit reached while trying discovered candidates.")
          return outcome
        end if

        attemptKey = normalizeInput(hostRecord.ip).trim + TAB + normalizeInput(userName).trim + TAB + normalizeInput(candidate.value).trim
        if runState.credential_attempt_keys.hasIndex(attemptKey) then continue

        runState.credential_attempt_keys[attemptKey] = 1
        outcome.attempts = outcome.attempts + 1
        connection = tryCredentialHostRecordAccess(runtimeContext.shell, hostRecord, userName, candidate.value)
        if connection == null then continue

        outcome.successes = outcome.successes + 1
        outcome.status = "intel-success"
        outcome.shell = connection
        outcome.host_ip = hostRecord.ip
        outcome.user = userName
        recordAcceptedTerminalAccess(connection, hostRecord, runState)
        appendLine(outcome.notes, "Discovered credential success: " + userName + " @ " + hostRecord.ip + " from " + normalizeInput(candidate.source).trim)
        addCredentialCacheRecord(runState.credential_cache, hostRecord.public_ip, hostRecord.lan_ip, userName, candidate.value, candidate.source)
        return outcome
      end for
    end for
  end for

  if outcome.attempts == 0 then
    outcome.status = "no-credential-attempts"
  else
    outcome.status = "no-credential-shell"
  end if

  return outcome
end function

printCredentialSummary = function(credentialResult)
  if credentialResult == null then return

  print("CRS V1 credential summary")
  print("Status: " + formatValueDisplay(credentialResult.status))
  print("Source host: " + formatValueDisplay(credentialResult.source_host))
  print("Attempts: " + credentialResult.attempts)
  print("Successes: " + credentialResult.successes)
  print("Password candidates: " + credentialResult.password_candidates)
  print("Files scanned: " + credentialResult.scanned_files)
  if credentialResult.loot_records != null then print("Loot records: " + credentialResult.loot_records)
  if credentialResult.host_ip != "" then print("Credential host: " + credentialResult.host_ip)
  if credentialResult.user != "" then print("Credential user: " + credentialResult.user)
  print("")
end function

getAccessHostComputer = function(accessObject)
  if accessObject == null then return null
  accessType = loginAccessType(accessObject)
  if not isCredentialAccessType(accessType) then return null
  return accessObject.host_computer
end function

findHostRecordForComputer = function(hostRecords, remoteComputer)
  if hostRecords == null then return null
  if remoteComputer == null then return null

  remotePublicIp = normalizeInput(remoteComputer.public_ip).trim
  remoteLocalIp = normalizeInput(remoteComputer.local_ip).trim

  for hostRecord in hostRecords
    if hostRecord == null then continue

    recordPublicIp = normalizeInput(hostRecord.public_ip).trim
    recordLocalIp = normalizeInput(hostRecord.lan_ip).trim
    if recordLocalIp == "" then recordLocalIp = normalizeInput(hostRecord.ip).trim

    if remoteLocalIp != "" and recordLocalIp != "" and remoteLocalIp == recordLocalIp then return hostRecord
  end for

  for hostRecord in hostRecords
    if hostRecord == null then continue

    recordPublicIp = normalizeInput(hostRecord.public_ip).trim
    if remotePublicIp != "" and recordPublicIp != "" and remotePublicIp == recordPublicIp then return hostRecord
  end for

  return null
end function

findWritableDeployFolder = function(remoteComputer)
  candidatePaths = ["/tmp", "/var/tmp", "/home/guest", "/home"]

  for candidatePath in candidatePaths
    folder = remoteComputer.File(candidatePath)
    if folder == null then continue
    if not folder.is_folder then continue
    if folder.has_permission("w") then return candidatePath
  end for

  homeFolder = remoteComputer.File("/home")
  if homeFolder != null and homeFolder.is_folder and homeFolder.has_permission("r") then
    for userFolder in homeFolder.get_folders
      if userFolder == null then continue
      if not userFolder.is_folder then continue
      if userFolder.has_permission("w") then return userFolder.path
    end for
  end if

  return ""
end function

copyOptionalAsset = function(localShell, remoteShell, localPath, remoteDir)
  if localShell == null then return 0
  localComputer = localShell.host_computer
  if localComputer == null then return 0

  localFile = localComputer.File(localPath)
  if localFile == null then return 0
  if localFile.is_folder then return 0

  copyResult = localShell.scp(localPath, remoteDir, remoteShell)
  if copyResult == 1 then return 1
  return 0
end function

copyAnyOptionalAsset = function(localShell, remoteShell, localPaths, remoteDir)
  if localPaths == null then return 0

  for localPath in localPaths
    if localPath == null then continue
    if normalizeInput(localPath).trim == "" then continue
    if copyOptionalAsset(localShell, remoteShell, localPath, remoteDir) then return 1
  end for

  return 0
end function

stageRemoteToolkit = function(runState, accessObject, targetRecord = null, preferredDir = "")
  outcome = {
    "status": "not-run",
    "remote_dir": "",
    "remote_program": "",
    "staged_paths": [],
    "notes": [],
  }

  if runState == null then
    outcome.status = "missing-state"
    return outcome
  end if

  if not runState.config.stage_tools then
    outcome.status = "disabled"
    return outcome
  end if

  if accessObject == null then
    outcome.status = "missing-access"
    return outcome
  end if

  if loginAccessType(accessObject) != "shell" then
    outcome.status = "not-shell"
    return outcome
  end if

  remoteComputer = getAccessHostComputer(accessObject)
  if remoteComputer == null then
    outcome.status = "missing-computer"
    return outcome
  end if

  if isSameComputer(runState.runtime.computer, remoteComputer) then
    outcome.status = "same-host"
    return outcome
  end if

  hostKey = buildHostKey(remoteComputer.public_ip, remoteComputer.local_ip)
  if runState.staged_host_keys.hasIndex(hostKey) then
    outcome.status = "already-staged"
    normalizedHostKey = normalizeCacheField(hostKey)
    for stagedEntry in runState.staged_paths
      if stagedEntry == null then continue
      if stagedEntry.host_key != normalizedHostKey then continue
      outcome.staged_paths.push(stagedEntry.path)
      if stagedEntry.type == "program" then outcome.remote_program = stagedEntry.path
    end for
    if outcome.remote_program != "" then
      pathParts = outcome.remote_program.split("/")
      if pathParts != null and pathParts.len > 1 then outcome.remote_dir = pathParts[0:pathParts.len - 1].join("/")
    end if
    return outcome
  end if

  remoteDir = normalizeInput(preferredDir).trim
  if remoteDir == "" then remoteDir = findWritableDeployFolder(remoteComputer)
  if remoteDir == "" then
    outcome.status = "no-remote-dir"
    appendLine(outcome.notes, "No writable remote folder found for toolkit staging.")
    return outcome
  end if

  remoteProgram = remoteDir + "/" + pathBaseName(runState.runtime.program_path)
  programCopyResult = runState.runtime.shell.scp(runState.runtime.program_path, remoteDir, accessObject)
  if not isApiSuccess(programCopyResult) then
    outcome.status = "copy-failed"
    appendLine(outcome.notes, "Program staging failed: " + normalizeInput(programCopyResult))
    return outcome
  end if

  if remoteComputer.File(remoteProgram) == null then
    outcome.status = "validation-failed"
    appendLine(outcome.notes, "Remote program validation failed after staging.")
    return outcome
  end if

  addStagedArtifact(runState, hostKey, remoteProgram, "program")
  outcome.remote_dir = remoteDir
  outcome.remote_program = remoteProgram
  outcome.staged_paths.push(remoteProgram)

  stagedAssets = [
    {"paths":["/lib/metaxploit.so", runState.config.lib_dir + "/metaxploit.so"], "name":"metaxploit.so", "type":"lib"},
    {"paths":["/lib/crypto.so", runState.config.lib_dir + "/crypto.so"], "name":"crypto.so", "type":"lib"},
    {"paths":[runState.outputs.signature_cache_file.path], "name":pathBaseName(runState.outputs.signature_cache_file.path), "type":"cache"},
    {"paths":[runState.outputs.credential_cache_file.path], "name":pathBaseName(runState.outputs.credential_cache_file.path), "type":"cache"},
    {"paths":[runState.outputs.host_cache_file.path], "name":pathBaseName(runState.outputs.host_cache_file.path), "type":"cache"},
    {"paths":[runState.outputs.surface_cache_file.path], "name":pathBaseName(runState.outputs.surface_cache_file.path), "type":"cache"},
    {"paths":[runState.outputs.loot_cache_file.path], "name":pathBaseName(runState.outputs.loot_cache_file.path), "type":"cache"},
  ]

  for stagedAsset in stagedAssets
    if copyAnyOptionalAsset(runState.runtime.shell, accessObject, stagedAsset.paths, remoteDir) then
      stagedPath = remoteDir + "/" + stagedAsset.name
      if remoteComputer.File(stagedPath) != null then
        addStagedArtifact(runState, hostKey, stagedPath, stagedAsset.type)
        outcome.staged_paths.push(stagedPath)
      end if
    end if
  end for

  runState.staged_toolkit = 1
  runState.staged_host_keys[hostKey] = 1
  runState.stage_result = outcome
  outcome.status = "staged"
  if targetRecord != null then appendLine(outcome.notes, "Toolkit staged on " + normalizeInput(targetRecord.ip).trim)
  return outcome
end function

buildRuntimeHostRecord = function(runtimeContext, seedHostRecord = null)
  if runtimeContext == null then return seedHostRecord
  if seedHostRecord != null then return seedHostRecord
  return {
    "ip": normalizeInput(runtimeContext.computer.local_ip).trim,
    "public_ip": normalizeInput(runtimeContext.computer.public_ip).trim,
    "lan_ip": normalizeInput(runtimeContext.computer.local_ip).trim,
    "gateway_ip": "",
    "role": "host",
    "priority": "medium",
    "score": 0,
    "open_ports": [],
    "source": "runtime-host",
  }
end function

dumpExploitSurface = function(targetRecord, runtimeContext, runState, portNumber, remoteLib, memoryAddress, scanInfo, originText = "remote")
  if runState == null then return 0
  if not runState.config.surface_report then return 0
  if remoteLib == null then return 0

  unsafeValues = extractUnsafeValues(scanInfo)
  if unsafeValues == null or unsafeValues.len == 0 then
    return addSurfaceRecord(runState, targetRecord, portNumber, remoteLib.lib_name, remoteLib.version, memoryAddress, "", scanInfo, originText)
  end if

  added = 0
  for unsafeValue in unsafeValues
    added = added + addSurfaceRecord(runState, targetRecord, portNumber, remoteLib.lib_name, remoteLib.version, memoryAddress, unsafeValue, scanInfo, originText)
  end for
  return added
end function

buildManualAssistKey = function(portNumber, memoryAddress, unsafeValue)
  return normalizeCacheField(portNumber) + TAB + normalizeCacheField(memoryAddress) + TAB + normalizeCacheField(unsafeValue)
end function

buildHostIntelKey = function(hostRecord)
  if hostRecord == null then return ""
  hostLocalIp = normalizeInput(hostRecord.lan_ip).trim
  if hostLocalIp == "" and is_lan_ip(normalizeInput(hostRecord.ip).trim) then hostLocalIp = normalizeInput(hostRecord.ip).trim
  return buildHostKey(normalizeInput(hostRecord.public_ip).trim, hostLocalIp)
end function

countLootRecordsForHost = function(runState, hostRecord, artifactType = "")
  if runState == null then return 0
  if hostRecord == null then return 0
  if runState.loot_records == null then return 0

  hostPublicIp = normalizeInput(hostRecord.public_ip).trim
  hostLocalIp = normalizeInput(hostRecord.lan_ip).trim
  if hostLocalIp == "" and is_lan_ip(normalizeInput(hostRecord.ip).trim) then hostLocalIp = normalizeInput(hostRecord.ip).trim
  wantedType = normalizeInput(artifactType).trim.lower
  matched = 0

  for lootRecord in runState.loot_records
    if lootRecord == null then continue
    if hostPublicIp != "" and normalizeInput(lootRecord.host_public).trim != hostPublicIp then continue
    if hostLocalIp != "" and normalizeInput(lootRecord.host_local).trim != hostLocalIp then continue
    if wantedType != "" and normalizeInput(lootRecord.artifact_type).trim.lower != wantedType then continue
    matched = matched + 1
  end for

  return matched
end function

buildLocalIntelScore = function(hostRecord, runState)
  if hostRecord == null then return -999999

  baseScore = hostPriorityScore(hostRecord, runState.target, runState)
  lootRecords = countLootRecordsForHost(runState, hostRecord)
  mailRecords = countLootRecordsForHost(runState, hostRecord, "mail")
  bankRecords = countLootRecordsForHost(runState, hostRecord, "bank")
  passwdRecords = countLootRecordsForHost(runState, hostRecord, "passwd")
  openPortCount = 0
  if hostRecord.open_ports != null then openPortCount = hostRecord.open_ports.len

  return baseScore + (lootRecords * 15) + (mailRecords * 6) + (bankRecords * 8) + (passwdRecords * 4) + openPortCount
end function

storeHostIntelRecord = function(runState, hostRecord, intelRecord)
  if runState == null then return 0
  if hostRecord == null then return 0
  intelKey = buildHostIntelKey(hostRecord)
  if intelKey == "" then return 0
  runState.host_intel[intelKey] = intelRecord
  return 1
end function

applyLocalIntelToHostRecord = function(hostRecord, intelRecord)
  if hostRecord == null or intelRecord == null then return 0

  hostRecord["reachable_from_chain"] = intelRecord.reachable_from_chain
  hostRecord["local_loot_records"] = intelRecord.loot_records
  hostRecord["local_mail_records"] = intelRecord.mail_records
  hostRecord["local_bank_records"] = intelRecord.bank_records
  hostRecord["local_passwd_records"] = intelRecord.passwd_records
  hostRecord["local_surface_records"] = intelRecord.local_surface_records
  hostRecord["local_next_hop_score"] = intelRecord.next_hop_score
  return 1
end function

collectManualSurfaceEntries = function(runState, targetRecord)
  entries = []
  seen = {}
  if runState == null then return entries
  if targetRecord == null then return entries
  if runState.surface_records == null then return entries

  targetIp = normalizeInput(targetRecord.ip).trim
  targetPublicIp = normalizeInput(targetRecord.public_ip).trim
  targetLocalIp = normalizeInput(targetRecord.lan_ip).trim

  for record in runState.surface_records
    if record == null then continue
    if normalizeInput(record.origin).trim != "remote-service" then continue

    sameHost = 0
    if normalizeInput(record.host_ip).trim == targetIp then sameHost = 1
    if not sameHost and targetPublicIp != "" and normalizeInput(record.host_public).trim == targetPublicIp then sameHost = 1
    if not sameHost and targetLocalIp != "" and normalizeInput(record.host_local).trim == targetLocalIp then sameHost = 1
    if not sameHost then continue

    unsafeValue = normalizeInput(record.unsafe).trim
    if unsafeValue == "" then continue

    entryKey = buildManualAssistKey(record.port, record.memory, unsafeValue)
    if seen.hasIndex(entryKey) then continue

    seen[entryKey] = 1
    entries.push({
      "port": normalizeInput(record.port).trim,
      "lib": normalizeInput(record.lib).trim,
      "version": normalizeInput(record.version).trim,
      "memory": normalizeInput(record.memory).trim,
      "unsafe": unsafeValue,
      "scan_info": normalizeInput(record.scan_info),
    })
  end for

  return entries
end function

runManualOverflow = function(metaLib, portNumber, routerLanIp, memoryAddress, unsafeValue, extraArg = "")
  if metaLib == null then return null
  extraText = normalizeInput(extraArg).trim
  if extraText != "" then return metaLib.overflow(memoryAddress, unsafeValue, extraText)
  return runOverflow(metaLib, portNumber, routerLanIp, memoryAddress, unsafeValue)
end function

manualExploitAssist = function(targetRecord, runtimeContext, runState)
  outcome = {
    "status": "",
    "keep_result": 0,
    "result": null,
    "raw_result_type": "",
    "result_type": "",
    "escalation_status": "",
    "selected_port": "",
    "selected_memory": "",
    "selected_unsafe": "",
    "sessions_opened": 0,
    "overflow_attempts": 0,
    "notes": [],
  }

  if runState == null or runtimeContext == null then return outcome
  if targetRecord == null then return outcome
  if not runState.config.manual_assist then return outcome
  if runState.config.non_interactive then
    outcome.status = "non-interactive"
    appendLine(outcome.notes, "Manual assist skipped in non-interactive mode.")
    return outcome
  end if

  surfaceEntries = collectManualSurfaceEntries(runState, targetRecord)
  if surfaceEntries == null or surfaceEntries.len == 0 then
    outcome.status = "no-surface"
    appendLine(outcome.notes, "Manual assist skipped because no remote-service surface entries are available for this target.")
    return outcome
  end if

  enableAnswer = normalizeInput(user_input("Manual exploit assist for " + normalizeInput(targetRecord.ip).trim + "? [y/N]: ")).trim.lower
  if not toYesNoFlag(enableAnswer, 0) then
    outcome.status = "skipped"
    return outcome
  end if

  displayCount = surfaceEntries.len
  if displayCount > MAX_MANUAL_ASSIST_OPTIONS then displayCount = MAX_MANUAL_ASSIST_OPTIONS

  print("CRS V1 manual exploit assist")
  entryIndex = 0
  for surfaceEntry in surfaceEntries
    if entryIndex >= displayCount then break
    print("" + (entryIndex + 1) + ". " + "port=" + surfaceEntry.port + " | " + surfaceEntry.lib + " v" + surfaceEntry.version + " | " + surfaceEntry.memory + " | " + surfaceEntry.unsafe)
    entryIndex = entryIndex + 1
  end for
  if surfaceEntries.len > displayCount then print("..." + (surfaceEntries.len - displayCount) + " more entries available in the surface cache.")

  selection = normalizeInput(user_input("Select entry [1-" + displayCount + ", M=manual, blank=skip]: ")).trim
  if selection == "" then
    outcome.status = "skipped"
    return outcome
  end if

  selectedPort = ""
  selectedMemory = ""
  selectedUnsafe = ""
  selectedExtraArg = ""
  selectedEntry = null

  if selection.lower == "m" then
    selectedPort = normalizeInput(user_input("Manual port [0 for router]: ")).trim
    selectedMemory = normalizeInput(user_input("Manual memory address: ")).trim
    selectedUnsafe = normalizeInput(user_input("Manual unsafe value: ")).trim
  else
    if not isNumericText(selection) then
      outcome.status = "invalid-selection"
      appendLine(outcome.notes, "Manual assist selection was not numeric.")
      return outcome
    end if

    selectedIndex = selection.val - 1
    if selectedIndex < 0 or selectedIndex >= displayCount then
      outcome.status = "invalid-selection"
      appendLine(outcome.notes, "Manual assist selection was outside the displayed range.")
      return outcome
    end if

    selectedEntry = surfaceEntries[selectedIndex]
    selectedPort = normalizeInput(selectedEntry.port).trim
    selectedMemory = normalizeInput(selectedEntry.memory).trim
    selectedUnsafe = normalizeInput(selectedEntry.unsafe).trim
  end if

  if not isNumericText(selectedPort) then
    outcome.status = "invalid-port"
    appendLine(outcome.notes, "Manual assist requires a numeric port.")
    return outcome
  end if
  if selectedMemory == "" or selectedUnsafe == "" then
    outcome.status = "invalid-selection"
    appendLine(outcome.notes, "Manual assist requires both memory address and unsafe value.")
    return outcome
  end if

  selectedExtraArg = normalizeInput(user_input("Extra arg [blank=auto/default]: ")).trim
  portNumber = selectedPort.val
  attackAddress = resolveAttackAddress(targetRecord, portNumber)
  if attackAddress == "" then
    outcome.status = "missing-address"
    appendLine(outcome.notes, "Manual assist could not resolve an attack address for port " + selectedPort + ".")
    return outcome
  end if

  if portNumber == 0 then
    session = runtimeContext.meta.net_use(attackAddress)
  else
    session = runtimeContext.meta.net_use(attackAddress, portNumber)
  end if

  if session == null then
    outcome.status = "session-failed"
    appendLine(outcome.notes, "Manual assist could not open a new session on " + attackAddress + ":" + selectedPort)
    return outcome
  end if

  outcome.sessions_opened = 1
  remoteLib = session.dump_lib
  if remoteLib == null then
    outcome.status = "lib-failed"
    appendLine(outcome.notes, "Manual assist failed to dump the target library.")
    return outcome
  end if

  if selectedEntry != null and normalizeInput(selectedEntry.lib).trim != "" and normalizeInput(remoteLib.lib_name).trim != normalizeInput(selectedEntry.lib).trim then
    appendLine(outcome.notes, "Manual assist library mismatch: expected " + normalizeInput(selectedEntry.lib).trim + " but loaded " + normalizeInput(remoteLib.lib_name).trim + ".")
  end if

  addSurfaceRecord(runState, targetRecord, selectedPort, remoteLib.lib_name, remoteLib.version, selectedMemory, selectedUnsafe, "", "manual-assist")
  outcome.overflow_attempts = 1
  result = runManualOverflow(remoteLib, portNumber, normalizeInput(targetRecord.lan_ip).trim, selectedMemory, selectedUnsafe, selectedExtraArg)
  if result == null then
    outcome.status = "manual-nohit"
    outcome.selected_port = selectedPort
    outcome.selected_memory = selectedMemory
    outcome.selected_unsafe = selectedUnsafe
    appendLine(outcome.notes, "Manual assist returned no result for " + selectedMemory + " / " + selectedUnsafe + ".")
    return outcome
  end if

  resultType = typeof(result)
  addSignatureCacheRecord(runState.signature_cache, remoteLib.lib_name, remoteLib.version, portNumber, selectedMemory, selectedUnsafe, resultType)
  outcome.result = result
  outcome.raw_result_type = resultType
  outcome.result_type = resultType
  outcome.status = classifyAttackStatus(resultType, result)
  outcome.selected_port = selectedPort
  outcome.selected_memory = selectedMemory
  outcome.selected_unsafe = selectedUnsafe
  appendLine(outcome.notes, "Manual assist attempted " + selectedMemory + " / " + selectedUnsafe + " -> " + resultType)
  if resultType == "string" then appendLine(outcome.notes, "Manual assist result: " + normalizeInput(result))
  if resultType == "number" then appendLine(outcome.notes, "Manual assist result: " + result)

  if resultType == "shell" then
    recordAcceptedTerminalAccess(result, targetRecord, runState)
    outcome.keep_result = 1
    return outcome
  end if

  if resultType == "computer" then
    escalationOutcome = attemptComputerShellEscalation(runtimeContext.shell, result, targetRecord, runState)
    outcome.escalation_status = escalationOutcome.status
    for noteLine in escalationOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for

    if escalationOutcome.shell != null then
      outcome.result = escalationOutcome.shell
      outcome.result_type = escalationOutcome.access_type
      outcome.status = escalationOutcome.status
      outcome.keep_result = 1
      return outcome
    end if

    outcome.keep_result = 1
    return outcome
  end if

  if resultType == "file" then
    fileOutcome = handleFileAttackResult(runtimeContext, runState, targetRecord, result, selectedExtraArg)
    outcome.status = fileOutcome.status
    for noteLine in fileOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for
    outcome.keep_result = 1
    return outcome
  end if

  return outcome
end function

collectLocalHacks = function(runtimeContext, runState, seedHostRecord = null)
  outcome = {
    "status": "not-run",
    "libraries": 0,
    "memory_zones": 0,
    "records_added": 0,
    "reachable_hosts": 0,
    "loot_hosts": 0,
    "mail_hosts": 0,
    "data_hosts": 0,
    "preferred_next_hop": "",
    "preferred_next_role": "",
    "preferred_next_score": "",
    "notes": [],
  }

  if runtimeContext == null or runState == null then
    outcome.status = "missing-state"
    return outcome
  end if

  if runtimeContext.meta == null then
    outcome.status = "missing-metaxploit"
    return outcome
  end if

  targetRecord = seedHostRecord
  if targetRecord == null then
    targetRecord = {
      "ip": normalizeInput(runtimeContext.computer.local_ip).trim,
      "public_ip": normalizeInput(runtimeContext.computer.public_ip).trim,
      "lan_ip": normalizeInput(runtimeContext.computer.local_ip).trim,
      "gateway_ip": "",
      "role": "host",
      "priority": "medium",
      "score": 0,
      "open_ports": [],
      "source": "local-runtime",
    }
  end if

  if targetRecord != null then
    targetPublicIp = normalizeInput(targetRecord.public_ip).trim
    targetLocalIp = normalizeInput(targetRecord.lan_ip).trim
    runtimePublicIp = normalizeInput(runtimeContext.computer.public_ip).trim
    runtimeLocalIp = normalizeInput(runtimeContext.computer.local_ip).trim
    if targetPublicIp != "" and runtimePublicIp != "" and targetPublicIp != runtimePublicIp then
      outcome.status = "skipped-remote-host"
      appendLine(outcome.notes, "Local hack scan skipped because runtime host differs from target foothold.")
      return outcome
    end if
    if targetLocalIp != "" and runtimeLocalIp != "" and targetLocalIp != runtimeLocalIp then
      outcome.status = "skipped-remote-host"
      appendLine(outcome.notes, "Local hack scan skipped because runtime host differs from target foothold.")
      return outcome
    end if
  end if

  lootOutcome = null
  if runState.config.loot_mode then
    lootOutcome = collectStructuredLoot(runtimeContext, runtimeContext.computer, runState.target, runState)
    if lootOutcome != null then runState.loot_result = lootOutcome
  end if

  for localLibName in ["net.so", "init.so", "kernel_module.so", "kernel_router.so"]
    yield
    localLib = runtimeContext.meta.load("/lib/" + localLibName)
    if localLib == null then continue

    memories = runtimeContext.meta.scan(localLib)
    if memories == null or typeof(memories) != "list" or memories.len == 0 then continue

    outcome.libraries = outcome.libraries + 1
    outcome.memory_zones = outcome.memory_zones + memories.len
    for memoryAddress in memories
      yield
      scanInfo = runtimeContext.meta.scan_address(localLib, memoryAddress)
      outcome.records_added = outcome.records_added + dumpExploitSurface(targetRecord, runtimeContext, runState, "local", localLib, memoryAddress, scanInfo, "local-lib")
    end for
  end for

  currentHostIp = normalizeInput(runtimeContext.computer.local_ip).trim
  bestNextHost = null
  bestNextScore = -999999

  if runState.ranked_hosts != null then
    for hostRecord in runState.ranked_hosts
      yield
      if hostRecord == null then continue

      intelRecord = {
        "host_ip": normalizeInput(hostRecord.ip).trim,
        "host_public": normalizeInput(hostRecord.public_ip).trim,
        "host_local": normalizeInput(hostRecord.lan_ip).trim,
        "role": normalizeInput(hostRecord.role).trim,
        "reachable_from_chain": 1,
        "loot_records": countLootRecordsForHost(runState, hostRecord),
        "mail_records": countLootRecordsForHost(runState, hostRecord, "mail"),
        "bank_records": countLootRecordsForHost(runState, hostRecord, "bank"),
        "passwd_records": countLootRecordsForHost(runState, hostRecord, "passwd"),
        "local_surface_records": 0,
        "next_hop_score": buildLocalIntelScore(hostRecord, runState),
      }

      if normalizeInput(hostRecord.ip).trim == currentHostIp or normalizeInput(hostRecord.lan_ip).trim == currentHostIp then
        intelRecord.local_surface_records = outcome.records_added
      end if

      storeHostIntelRecord(runState, hostRecord, intelRecord)
      applyLocalIntelToHostRecord(hostRecord, intelRecord)
      outcome.reachable_hosts = outcome.reachable_hosts + 1

      if intelRecord.loot_records > 0 then outcome.loot_hosts = outcome.loot_hosts + 1
      roleText = normalizeInput(hostRecord.role).trim.lower
      if roleText == "mail-server" or intelRecord.mail_records > 0 then outcome.mail_hosts = outcome.mail_hosts + 1
      if roleText == "data-server" or intelRecord.bank_records > 0 or intelRecord.passwd_records > 0 then outcome.data_hosts = outcome.data_hosts + 1

      if intelRecord.host_ip == currentHostIp or intelRecord.host_local == currentHostIp then continue
      if hostRecord.open_ports == null or hostRecord.open_ports.len == 0 then
        if intelRecord.loot_records == 0 then continue
      end if

      if bestNextHost == null or intelRecord.next_hop_score > bestNextScore then
        bestNextHost = hostRecord
        bestNextScore = intelRecord.next_hop_score
      else if intelRecord.next_hop_score == bestNextScore and normalizeInput(hostRecord.ip).trim < normalizeInput(bestNextHost.ip).trim then
        bestNextHost = hostRecord
        bestNextScore = intelRecord.next_hop_score
      end if
    end for
  end if

  if bestNextHost != null then
    outcome.preferred_next_hop = normalizeInput(bestNextHost.ip).trim
    outcome.preferred_next_role = normalizeInput(bestNextHost.role).trim
    outcome.preferred_next_score = "" + bestNextScore
    runState.preferred_next_host = outcome.preferred_next_hop
  else
    runState.preferred_next_host = ""
  end if

  if outcome.libraries == 0 and outcome.reachable_hosts == 0 then
    outcome.status = "no-local-libs"
  else if outcome.libraries == 0 then
    outcome.status = "intel-only"
  else
    outcome.status = "complete"
  end if
  appendLine(outcome.notes, "Local hack scan libraries: " + outcome.libraries)
  appendLine(outcome.notes, "Local hack scan records: " + outcome.records_added)
  appendLine(outcome.notes, "Chain hosts reachable: " + outcome.reachable_hosts)
  appendLine(outcome.notes, "Hosts with loot hints: " + outcome.loot_hosts)
  appendLine(outcome.notes, "Mail hosts: " + outcome.mail_hosts)
  appendLine(outcome.notes, "Data hosts: " + outcome.data_hosts)
  if lootOutcome != null then appendLine(outcome.notes, "Current host loot records: " + lootOutcome.records.len)
  if outcome.preferred_next_hop != "" then
    appendLine(outcome.notes, "Preferred next hop: " + outcome.preferred_next_hop + " (" + outcome.preferred_next_role + ", score=" + outcome.preferred_next_score + ")")
  else
    appendLine(outcome.notes, "Preferred next hop: -")
  end if
  runState.local_recon = outcome
  return outcome
end function

buildWorkerArgs = function(runConfig, targetContext, remoteDir, nextPivotDepth, workerTargetIp = "")
  argParts = []

  argParts.push("--mode")
  argParts.push("worker")
  argParts.push("--non-interactive")
  argParts.push("1")
  argParts.push("--open-terminal")
  argParts.push("" + runConfig.open_terminal)
  argParts.push("--stop-on-success")
  argParts.push("" + runConfig.stop_on_success)
  argParts.push("--pivot-depth")
  argParts.push("" + nextPivotDepth)
  argParts.push("--max-pivot-depth")
  argParts.push("" + runConfig.max_pivot_depth)

  effectiveTargetIp = normalizeInput(workerTargetIp).trim
  if effectiveTargetIp == "" then effectiveTargetIp = targetContext.target_ip

  if effectiveTargetIp != "" then
    argParts.push("--target-ip")
    argParts.push(effectiveTargetIp)
  end if

  if targetContext.target_lan_ip != "" then
    argParts.push("--target-lan-ip")
    argParts.push(targetContext.target_lan_ip)
  end if

  if targetContext.target_user != "" then
    argParts.push("--target-user")
    argParts.push(targetContext.target_user)
  end if

  if remoteDir != "" then
    argParts.push("--shared-dir")
    argParts.push(remoteDir)
    argParts.push("--lib-dir")
    argParts.push(remoteDir)
  end if

  return argParts.join(" ")
end function

launchRemoteExplorer = function(accessObject)
  if accessObject == null then return "missing-access"
  if loginAccessType(accessObject) != "shell" then return "not-shell"

  remoteComputer = getAccessHostComputer(accessObject)
  if remoteComputer == null then return "missing-computer"

  lastError = ""
  for candidatePath in ["FileExplorer.exe", "/root/FileExplorer.exe", "/usr/FileExplorer.exe", "/bin/FileExplorer.exe", "/usr/bin/FileExplorer.exe"]
    if candidatePath.indexOf("/") != null then
      candidateFile = remoteComputer.File(candidatePath)
      if candidateFile == null then continue
      if candidateFile.is_folder then continue
    end if

    launchResult = accessObject.launch(candidatePath, "")
    if launchResult == null or launchResult == 1 then return "launched"
    if lastError == "" and isError(launchResult) then lastError = normalizeInput(launchResult).trim
  end for

  if lastError != "" then return lastError
  return "missing-explorer"
end function

shouldAttemptRouterHandoff = function(runState, acceptedRecord, acceptedAccess)
  if acceptedRecord == null then return 0
  if acceptedAccess == null then return 0
  if loginAccessType(acceptedAccess) != "shell" then return 0
  if runState == null then return 0
  if runState.config.mode == "worker" then return 0
  if runState.pivot_depth >= runState.config.max_pivot_depth then return 0

  roleText = normalizeInput(acceptedRecord.role).trim.lower
  if roleText.indexOf("gateway") == null then return 0

  targetLanIp = normalizeInput(runState.target.target_lan_ip).trim
  acceptedLanIp = normalizeInput(acceptedRecord.lan_ip).trim
  if targetLanIp != "" and acceptedLanIp == targetLanIp then return 0

  for hostRecord in runState.ranked_hosts
    if hostRecord == null then continue
    if normalizeInput(hostRecord.ip).trim == normalizeInput(acceptedRecord.ip).trim then continue
    return 1
  end for

  return 0
end function

attemptRouterHandoff = function(runState, acceptedRecord, acceptedAccess)
  outcome = {
    "status": "not-run",
    "remote_dir": "",
    "remote_program": "",
    "launch_args": "",
    "notes": [],
  }

  if runState == null then
    outcome.status = "missing-state"
    return outcome
  end if

  if not shouldAttemptRouterHandoff(runState, acceptedRecord, acceptedAccess) then
    outcome.status = "not-needed"
    return outcome
  end if

  remoteComputer = getAccessHostComputer(acceptedAccess)
  if remoteComputer == null then
    outcome.status = "missing-remote-computer"
    return outcome
  end if

  hostKey = buildHostKey(remoteComputer.public_ip, remoteComputer.local_ip)
  if runState.launched_workers.hasIndex(hostKey) then
    outcome.status = "already-launched"
    return outcome
  end if

  remoteDir = findWritableDeployFolder(remoteComputer)
  if remoteDir == "" then
    outcome.status = "no-remote-dir"
    appendLine(outcome.notes, "No writable remote folder for router handoff.")
    return outcome
  end if

  stageOutcome = stageRemoteToolkit(runState, acceptedAccess, acceptedRecord, remoteDir)
  runState.stage_result = stageOutcome
  for noteLine in stageOutcome.notes
    appendLine(outcome.notes, noteLine)
  end for
  if stageOutcome.status != "staged" and stageOutcome.status != "already-staged" then
    outcome.status = stageOutcome.status
    return outcome
  end if

  remoteProgram = stageOutcome.remote_program
  if remoteProgram == "" then remoteProgram = remoteDir + "/" + pathBaseName(runState.runtime.program_path)
  workerTargetIp = normalizeInput(acceptedRecord.lan_ip).trim
  if workerTargetIp == "" then workerTargetIp = normalizeInput(remoteComputer.local_ip).trim
  launchArgs = buildWorkerArgs(runState.config, runState.target, remoteDir, runState.pivot_depth + 1, workerTargetIp)
  launchResult = acceptedAccess.launch(remoteProgram, launchArgs)
  if launchResult != null and launchResult != 1 then
    outcome.status = "launch-failed"
    appendLine(outcome.notes, "Worker launch failed: " + normalizeInput(launchResult))
    return outcome
  end if

  runState.launched_workers[hostKey] = 1
  outcome.status = "launched"
  outcome.remote_dir = remoteDir
  outcome.remote_program = remoteProgram
  outcome.launch_args = launchArgs
  appendLine(outcome.notes, "Router handoff launched from " + normalizeInput(acceptedRecord.ip).trim)
  return outcome
end function

executeMissionAction = function(runState, accessObject, targetRecord = null)
  outcome = {
    "status": "not-run",
    "mode": "",
    "records": 0,
    "scanned_files": 0,
    "notes": [],
  }

  if runState == null then
    outcome.status = "missing-state"
    return outcome
  end if

  missionMode = normalizeMissionActionMode(runState.config.mission_action, "loot")
  outcome.mode = missionMode
  if missionMode == "off" then
    outcome.status = "disabled"
    return outcome
  end if

  if not runState.config.loot_mode then
    outcome.status = "loot-disabled"
    appendLine(outcome.notes, "Mission action requires loot mode to be enabled.")
    runState.mission_action_result = outcome
    return outcome
  end if

  if accessObject == null then
    outcome.status = "missing-access"
    return outcome
  end if

  remoteComputer = getAccessHostComputer(accessObject)
  if remoteComputer == null then
    outcome.status = "missing-computer"
    return outcome
  end if

  lootOutcome = collectStructuredLoot(runState.runtime, remoteComputer, runState.target, runState)
  runState.loot_result = lootOutcome
  if lootOutcome != null then
    outcome.scanned_files = lootOutcome.scanned_files
    for noteLine in lootOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for
  end if

  matchedLoot = collectMissionLootRecords(runState, remoteComputer, missionMode)
  outcome.records = matchedLoot.len

  if targetRecord != null then
    appendLine(outcome.notes, "Mission action target: " + normalizeInput(targetRecord.ip).trim)
  else
    appendLine(outcome.notes, "Mission action target: " + normalizeInput(remoteComputer.local_ip).trim)
  end if

  if matchedLoot.len == 0 then
    outcome.status = "no-records"
    appendLine(outcome.notes, "Mission action mode " + missionMode + " found no matching structured records.")
    runState.mission_action_result = outcome
    return outcome
  end if

  typeCounts = {}
  for lootRecord in matchedLoot
    if lootRecord == null then continue
    artifactType = normalizeInput(lootRecord.artifact_type).trim.lower
    if artifactType == "" then artifactType = "unknown"
    if not typeCounts.hasIndex(artifactType) then typeCounts[artifactType] = 0
    typeCounts[artifactType] = typeCounts[artifactType] + 1
  end for

  summaryParts = []
  for artifactType in ["passwd", "mail", "bank", "unknown"]
    if not typeCounts.hasIndex(artifactType) then continue
    summaryParts.push(artifactType + "=" + typeCounts[artifactType])
  end for

  outcome.status = "records=" + matchedLoot.len
  appendLine(outcome.notes, "Mission action mode " + missionMode + " matched " + matchedLoot.len + " records.")
  if summaryParts.len > 0 then appendLine(outcome.notes, "Mission action breakdown: " + summaryParts.join(", "))
  runState.mission_action_result = outcome
  return outcome
end function

findNamedFileInFolder = function(folderObject, wantedName)
  if folderObject == null then return null
  if not folderObject.is_folder then return null
  if not folderObject.has_permission("r") then return null

  for fileObject in folderObject.get_files
    if fileObject == null then continue
    if normalizeInput(fileObject.name).trim.lower == normalizeInput(wantedName).trim.lower then return fileObject
  end for

  return null
end function

findPasswdFileFromAttackFile = function(fileObject)
  if fileObject == null then return null
  if typeof(fileObject) != "file" then return null

  if not fileObject.is_folder then
    if normalizeInput(fileObject.name).trim.lower == "passwd" and not fileObject.is_binary and fileObject.has_permission("r") then return fileObject
    return null
  end if

  if normalizeInput(fileObject.path).trim == "/etc" then
    return findNamedFileInFolder(fileObject, "passwd")
  end if

  currentFolder = fileObject
  guard = 0
  while currentFolder != null and normalizeInput(currentFolder.path).trim != "/" and guard < 32
    currentFolder = currentFolder.parent
    guard = guard + 1
  end while

  if currentFolder == null then return null
  if not currentFolder.is_folder then return null
  if not currentFolder.has_permission("r") then return null

  for folderEntry in currentFolder.get_folders
    if folderEntry == null then continue
    if normalizeInput(folderEntry.path).trim != "/etc" then continue
    return findNamedFileInFolder(folderEntry, "passwd")
  end for

  return null
end function

buildFileResultHostHints = function(runState, targetRecord, extraArg = "")
  hostPublicIp = ""
  hostLocalIp = ""

  if targetRecord != null then
    hostPublicIp = normalizeInput(targetRecord.public_ip).trim
    hostLocalIp = normalizeInput(targetRecord.lan_ip).trim
    if hostPublicIp == "" and not is_lan_ip(normalizeInput(targetRecord.ip).trim) then hostPublicIp = normalizeInput(targetRecord.ip).trim
    if hostLocalIp == "" and is_lan_ip(normalizeInput(targetRecord.ip).trim) then hostLocalIp = normalizeInput(targetRecord.ip).trim
  end if

  if normalizeInput(extraArg).trim != "" then hostLocalIp = normalizeInput(extraArg).trim
  return {
    "host_public": hostPublicIp,
    "host_local": hostLocalIp,
  }
end function

handleFileAttackResult = function(runtimeContext, runState, targetRecord, fileResult, extraArg = "")
  outcome = {
    "status": "file",
    "loot_added": 0,
    "credential_records": 0,
    "notes": [],
  }

  if runtimeContext == null or runState == null then
    outcome.status = "file-missing-state"
    return outcome
  end if
  if fileResult == null or typeof(fileResult) != "file" then return outcome

  hostHints = buildFileResultHostHints(runState, targetRecord, extraArg)
  pathLower = normalizeInput(fileResult.path).trim.lower

  passwdFile = findPasswdFileFromAttackFile(fileResult)
  if passwdFile != null then
    passwdOutcome = addPasswdLootFromFile(runtimeContext, runState, hostHints.host_public, hostHints.host_local, passwdFile, "attack-file-passwd")
    outcome.loot_added = outcome.loot_added + passwdOutcome.added
    outcome.credential_records = outcome.credential_records + passwdOutcome.credential_records
    if passwdOutcome.users > 0 then
      outcome.status = "file-passwd"
      appendLine(outcome.notes, "File result exposed /etc/passwd with " + passwdOutcome.users + " user entries.")
      appendLine(outcome.notes, "File result added " + passwdOutcome.credential_records + " credential cache records from passwd.")
    end if
  end if

  if not fileResult.is_folder and fileResult.has_permission("r") and not fileResult.is_binary then
    if pathLower.indexOf("/config/mail.txt") != null then
      added = addStructuredLootFromHostHints(runtimeContext, runState, hostHints.host_public, hostHints.host_local, fileResult, pathBaseName(fileResult.path), "mail")
      outcome.loot_added = outcome.loot_added + added
      if added > 0 then
        outcome.status = "file-mail"
        appendLine(outcome.notes, "File result added mail loot records from " + fileResult.path)
      end if
    end if

    if pathLower.indexOf("/config/bank.txt") != null then
      added = addStructuredLootFromHostHints(runtimeContext, runState, hostHints.host_public, hostHints.host_local, fileResult, pathBaseName(fileResult.path), "bank")
      outcome.loot_added = outcome.loot_added + added
      if added > 0 then
        outcome.status = "file-bank"
        appendLine(outcome.notes, "File result added bank loot records from " + fileResult.path)
      end if
    end if
  end if

  if outcome.loot_added == 0 and outcome.credential_records == 0 and outcome.status == "file" then
    outcome.status = "file-no-loot"
    appendLine(outcome.notes, "File result did not expose structured loot or passwd credentials.")
  end if

  return outcome
end function

scoreFileAttackOutcome = function(fileOutcome)
  if fileOutcome == null then return 0
  if fileOutcome.credential_records > 0 then return 3
  if fileOutcome.loot_added > 0 then return 2
  return 1
end function

cleanupAccessArtifacts = function(accessObject, runState)
  outcome = {
    "status": "not-run",
    "cleaned": 0,
    "mode": "",
    "notes": [],
  }

  if runState == null then
    outcome.status = "missing-state"
    return outcome
  end if

  cleanupMode = normalizeCleanupMode(runState.config.cleanup_mode, "prompt")
  outcome.mode = cleanupMode
  if cleanupMode == "off" then
    outcome.status = "disabled"
    return outcome
  end if

  if accessObject == null then
    outcome.status = "missing-access"
    return outcome
  end if

  remoteComputer = getAccessHostComputer(accessObject)
  if remoteComputer == null then
    outcome.status = "missing-computer"
    return outcome
  end if

  effectiveMode = cleanupMode
  if cleanupMode == "prompt" then
    if runState.config.non_interactive then
      effectiveMode = "safe"
    else
      response = normalizeInput(user_input("Cleanup staged artifacts on " + formatValueDisplay(remoteComputer.local_ip) + " [safe/wipe/skip]: ")).trim.lower
      if response == "wipe" or response == "w" then
        effectiveMode = "wipe"
      else if response == "safe" or response == "s" or response == "y" or response == "yes" then
        effectiveMode = "safe"
      else
        effectiveMode = "off"
      end if
    end if
  end if

  if effectiveMode == "off" then
    outcome.status = "skipped"
    return outcome
  end if

  hostKey = buildHostKey(remoteComputer.public_ip, remoteComputer.local_ip)
  for stagedEntry in runState.staged_paths
    if stagedEntry == null then continue
    if stagedEntry.host_key != normalizeCacheField(hostKey) then continue
    if stagedEntry.type != "cache" then continue

    stagedFile = remoteComputer.File(stagedEntry.path)
    if stagedFile == null then continue
    deleteResult = stagedFile.delete
    if not isError(deleteResult) then
      outcome.cleaned = outcome.cleaned + 1
    end if
  end for

  if effectiveMode == "wipe" then
    systemLog = remoteComputer.File("/var/system.log")
    if systemLog != null and not systemLog.is_folder and systemLog.has_permission("w") then
      clearResult = systemLog.set_content("")
      if isApiSuccess(clearResult) then
        outcome.cleaned = outcome.cleaned + 1
        appendLine(outcome.notes, "System log truncated.")
      end if
    end if
  end if

  if outcome.cleaned == 0 then
    outcome.status = "nothing-cleaned"
  else
    outcome.status = "complete"
  end if
  runState.cleanup_result = outcome
  return outcome
end function

finalizeAcceptedAccess = function(runState)
  outcome = {
    "status": "no-access",
    "accepted_type": "",
    "accepted_access_level": "",
    "accepted_host": "",
    "explorer_status": "",
    "handoff_status": "",
    "stage_status": "",
    "local_recon_status": "",
    "local_recon_next_hop": "",
    "mission_action_status": "",
    "loot_status": "",
    "cleanup_status": "",
    "notes": [],
  }

  acceptedAccess = runState.accepted_shell
  acceptedLevel = normalizeInput(runState.accepted_access_level).trim
  if acceptedAccess == null then
    if runState.provisional_shell == null then return outcome
    acceptedAccess = runState.provisional_shell
    acceptedLevel = normalizeInput(runState.provisional_access_level).trim
  end if

  acceptedType = loginAccessType(acceptedAccess)
  acceptedComputer = getAccessHostComputer(acceptedAccess)
  acceptedRecord = findHostRecordForComputer(runState.ranked_hosts, acceptedComputer)
  if acceptedRecord == null then acceptedRecord = runState.selected_host_record

  outcome.accepted_type = acceptedType
  outcome.accepted_access_level = acceptedLevel
  if acceptedRecord != null then outcome.accepted_host = normalizeInput(acceptedRecord.ip).trim

  if shouldAttemptRouterHandoff(runState, acceptedRecord, acceptedAccess) then
    handoffOutcome = attemptRouterHandoff(runState, acceptedRecord, acceptedAccess)
    runState.handoff_result = handoffOutcome
    outcome.handoff_status = handoffOutcome.status
    if runState.stage_result != null then outcome.stage_status = runState.stage_result.status
    for noteLine in handoffOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for

    if handoffOutcome.status == "launched" then
      outcome.status = "router-handoff"
      outcome.mission_action_status = "deferred-router-handoff"
      runState.final_result = outcome
      return outcome
    end if
  end if

  stageOutcome = stageRemoteToolkit(runState, acceptedAccess, acceptedRecord)
  if stageOutcome != null then
    runState.stage_result = stageOutcome
    outcome.stage_status = stageOutcome.status
    for noteLine in stageOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for
  end if

  localReconOutcome = collectLocalHacks(runState.runtime, runState, acceptedRecord)
  if localReconOutcome != null then
    outcome.local_recon_status = localReconOutcome.status
    outcome.local_recon_next_hop = localReconOutcome.preferred_next_hop
    for noteLine in localReconOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for
  end if

  if runState.loot_records != null and runState.loot_records.len > 0 then
    outcome.loot_status = "records=" + runState.loot_records.len
  else if runState.config.loot_mode then
    outcome.loot_status = "enabled"
  else
    outcome.loot_status = "disabled"
  end if

  missionActionOutcome = executeMissionAction(runState, acceptedAccess, acceptedRecord)
  if missionActionOutcome != null then
    outcome.mission_action_status = missionActionOutcome.status
    if missionActionOutcome.records > 0 then outcome.loot_status = "records=" + missionActionOutcome.records
    for noteLine in missionActionOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for
  end if

  if acceptedLevel == "guest" then
    if runState.config.open_terminal then acceptedAccess.start_terminal
    cleanupOutcome = cleanupAccessArtifacts(acceptedAccess, runState)
    outcome.cleanup_status = cleanupOutcome.status
    for noteLine in cleanupOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for
    outcome.status = "guest-shell"
    runState.final_result = outcome
    return outcome
  end if

  if acceptedType == "shell" then
    explorerStatus = launchRemoteExplorer(acceptedAccess)
    outcome.explorer_status = explorerStatus
    if runState.config.open_terminal then acceptedAccess.start_terminal
    outcome.status = "final-shell"
  else
    if runState.config.open_terminal then acceptedAccess.start_terminal
    outcome.status = "terminal-access"
  end if

  cleanupOutcome = cleanupAccessArtifacts(acceptedAccess, runState)
  outcome.cleanup_status = cleanupOutcome.status
  for noteLine in cleanupOutcome.notes
    appendLine(outcome.notes, noteLine)
  end for

  runState.final_result = outcome
  return outcome
end function

shouldDeferCredentialReuseToRouterHandoff = function(runState)
  if runState == null then return 0
  if runState.accepted_shell == null then return 0

  acceptedAccess = runState.accepted_shell
  acceptedComputer = getAccessHostComputer(acceptedAccess)
  acceptedRecord = findHostRecordForComputer(runState.ranked_hosts, acceptedComputer)
  if acceptedRecord == null then acceptedRecord = runState.selected_host_record

  return shouldAttemptRouterHandoff(runState, acceptedRecord, acceptedAccess)
end function

hasRecordedShellAccess = function(runState)
  if runState == null then return 0
  if runState.accepted_shell != null then return 1
  if runState.provisional_shell != null then return 1
  return 0
end function

printFinalSummary = function(finalResult)
  if finalResult == null then return

  print("CRS V1 final summary")
  print("Status: " + formatValueDisplay(finalResult.status))
  print("Accepted type: " + formatValueDisplay(finalResult.accepted_type))
  print("Accepted access level: " + formatValueDisplay(finalResult.accepted_access_level))
  print("Accepted host: " + formatValueDisplay(finalResult.accepted_host))
  print("Explorer status: " + formatValueDisplay(finalResult.explorer_status))
  print("Handoff status: " + formatValueDisplay(finalResult.handoff_status))
  print("Stage status: " + formatValueDisplay(finalResult.stage_status))
  print("Local recon status: " + formatValueDisplay(finalResult.local_recon_status))
  print("Local next hop: " + formatValueDisplay(finalResult.local_recon_next_hop))
  print("Mission action: " + formatValueDisplay(finalResult.mission_action_status))
  print("Loot status: " + formatValueDisplay(finalResult.loot_status))
  print("Cleanup status: " + formatValueDisplay(finalResult.cleanup_status))
  print("")
end function

describeCurrentHost = function(runtimeContext)
  publicIp = formatValueDisplay(runtimeContext.computer.public_ip)
  localIp = formatValueDisplay(runtimeContext.computer.local_ip)
  return publicIp + " / " + localIp
end function

describeCurrentRouter = function(runtimeContext)
  if runtimeContext.current_router == null then return "-"

  publicIp = formatValueDisplay(runtimeContext.current_router.public_ip)
  localIp = formatValueDisplay(runtimeContext.current_router.local_ip)
  return publicIp + " / " + localIp
end function

buildStartupSummaryLines = function(runtimeContext, runConfig, targetContext, outputFiles)
  rows = []
  rows.push("Build" + TAB + SCRIPT_BUILD)
  rows.push("Date" + TAB + formatValueDisplay(runtimeContext.current_date))
  rows.push("User" + TAB + formatValueDisplay(runtimeContext.active_user))
  rows.push("Program" + TAB + formatValueDisplay(runtimeContext.program_path))
  rows.push("Current host" + TAB + describeCurrentHost(runtimeContext))
  rows.push("Current router" + TAB + describeCurrentRouter(runtimeContext))
  rows.push("Requested mode" + TAB + formatValueDisplay(runConfig.requested_mode))
  rows.push("Resolved mode" + TAB + formatValueDisplay(runConfig.mode))
  rows.push("Entry type" + TAB + formatValueDisplay(targetContext.entry_type))
  rows.push("Entry IP" + TAB + formatValueDisplay(targetContext.entry_ip))
  rows.push("Target IP" + TAB + formatValueDisplay(targetContext.target_ip))
  rows.push("Target LAN IP" + TAB + formatValueDisplay(targetContext.target_lan_ip))
  rows.push("Target user" + TAB + formatValueDisplay(targetContext.target_user))
  rows.push("Inside LAN" + TAB + targetContext.inside_lan)
  rows.push("Router hint" + TAB + targetContext.router_hint)
  rows.push("Exact internal target" + TAB + targetContext.exact_internal_target)
  rows.push("Metaxploit loaded" + TAB + (runtimeContext.meta != null))
  rows.push("Crypto loaded" + TAB + (runtimeContext.crypto != null))
  rows.push("Output dir" + TAB + formatValueDisplay(outputFiles.base_dir))
  rows.push("Report file" + TAB + formatValueDisplay(outputFiles.report_file.path))
  rows.push("Surface cache" + TAB + formatValueDisplay(outputFiles.surface_cache_file.path))
  rows.push("Loot cache" + TAB + formatValueDisplay(outputFiles.loot_cache_file.path))
  rows.push("Manual assist" + TAB + runConfig.manual_assist)
  rows.push("Mission action" + TAB + formatValueDisplay(runConfig.mission_action))
  rows.push("Cleanup mode" + TAB + formatValueDisplay(runConfig.cleanup_mode))
  return rows
end function

printStartupSummary = function(runtimeContext, runConfig, targetContext, outputFiles)
  rows = buildStartupSummaryLines(runtimeContext, runConfig, targetContext, outputFiles)
  print("CRS V1 startup summary")
  for row in rows
    parts = row.split(TAB)
    if parts == null or parts.len < 2 then
      print(row)
    else
      print(parts[0] + ": " + parts[1])
    end if
  end for
  print("")
end function

writeStartupReport = function(runtimeContext, runConfig, targetContext, outputFiles)
  reportLines = []
  appendLine(reportLines, "CRS V1 startup report")
  appendLine(reportLines, "====================")
  appendLine(reportLines, "")

  summaryRows = buildStartupSummaryLines(runtimeContext, runConfig, targetContext, outputFiles)
  for row in summaryRows
    appendLine(reportLines, row)
  end for

  return outputFiles.report_file.set_content(reportLines.join(NL))
end function

serviceName = function(portNumber)
  if portNumber == 0 then return "router-kernel"
  if portNumber == 21 then return "ftp"
  if portNumber == 22 then return "ssh"
  if portNumber == 25 then return "smtp"
  if portNumber == 53 then return "dns"
  if portNumber == 80 then return "http"
  if portNumber == 110 then return "pop3"
  if portNumber == 111 then return "rpc"
  if portNumber == 139 then return "netbios"
  if portNumber == 141 then return "bank-sql"
  if portNumber == 143 then return "imap"
  if portNumber == 443 then return "https"
  if portNumber == 445 then return "smb"
  if portNumber == 587 then return "smtp-submission"
  if portNumber == 993 then return "imaps"
  if portNumber == 995 then return "pop3s"
  if portNumber == 1222 then return "rshell"
  if portNumber == 1542 then return "repository"
  if portNumber == 1883 then return "smart-appliance"
  if portNumber == 3306 then return "criminals-sql"
  if portNumber == 3307 then return "students-sql"
  if portNumber == 3308 then return "employees-sql"
  if portNumber == 5432 then return "postgres"
  if portNumber == 5555 then return "adb"
  if portNumber == 6667 then return "chat"
  if portNumber == 37777 then return "cctv"
  if portNumber == 8080 then return "router-http"
  return "unknown"
end function

serviceWeight = function(portNumber)
  if portNumber == 21 then return 3
  if portNumber == 22 then return 3
  if portNumber == 25 then return 3
  if portNumber == 53 then return 2
  if portNumber == 80 then return 4
  if portNumber == 141 then return 5
  if portNumber == 443 then return 4
  if portNumber == 3306 then return 5
  if portNumber == 3307 then return 5
  if portNumber == 3308 then return 5
  if portNumber == 5432 then return 5
  if portNumber == 8080 then return 3
  if portNumber == 1222 then return 4
  if portNumber == 1542 then return 4
  if portNumber == 1883 then return 2
  if portNumber == 5555 then return 4
  if portNumber == 6667 then return 3
  if portNumber == 37777 then return 2
  return 1
end function

priorityLabel = function(scoreValue)
  if scoreValue >= 8 then return "high"
  if scoreValue >= 4 then return "medium"
  return "low"
end function

makePortInfo = function(portNumber)
  return {
    "port": portNumber,
    "service": serviceName(portNumber),
  }
end function

pushOpenPort = function(openPorts, seen, portNumber)
  portKey = "" + portNumber
  if listHasValue(seen, portKey) then return 0
  seen.push(portKey)
  openPorts.push(makePortInfo(portNumber))
  return 1
end function

collectRouterEntryPorts = function(router)
  openPorts = []
  seen = []
  if router == null then return openPorts

  pushOpenPort(openPorts, seen, 0)

  usedPorts = router.used_ports
  if usedPorts == null then return openPorts

  for portObj in usedPorts
    if portObj == null then continue
    if portObj.is_closed then continue
    pushOpenPort(openPorts, seen, portObj.port_number)
  end for

  return openPorts
end function

collectOpenPorts = function(router, ipAddress)
  openPorts = []
  seen = []
  if router == null then return openPorts

  ports = router.device_ports(ipAddress)
  if ports == null then return openPorts

  for portObj in ports
    if portObj == null then continue
    if portObj.is_closed then continue
    pushOpenPort(openPorts, seen, portObj.port_number)
  end for

  return openPorts
end function

scoreHost = function(ipAddress, openPorts)
  score = 0
  if isLikelyRouterLanIp(ipAddress) then score = score + 1
  if openPorts == null then return score

  for portInfo in openPorts
    if portInfo == null then continue
    score = score + serviceWeight(portInfo.port)
  end for

  return score
end function

hostRoleGuess = function(ipAddress, openPorts)
  if isLikelyRouterLanIp(ipAddress) then
    if openPorts == null or openPorts.len == 0 then return "adjacent-gateway"
    return "gateway"
  end if

  if openPorts == null or openPorts.len == 0 then return "host"

  for portInfo in openPorts
    if portInfo.port == 5555 then return "smartphone"
    if portInfo.port == 3306 or portInfo.port == 5432 or portInfo.port == 141 then return "data-server"
    if portInfo.port == 80 or portInfo.port == 443 or portInfo.port == 8080 then return "web-server"
    if portInfo.port == 25 then return "mail-server"
    if portInfo.port == 1883 then return "iot-device"
    if portInfo.port == 1542 then return "repository-server"
  end for

  return "host"
end function

makeHostRecord = function(ipAddress, roleText, priorityText, scoreValue, openPorts, sourceText, publicIp = "", lanIp = "", gatewayIp = "")
  hostIp = normalizeInput(ipAddress).trim
  normalizedPublicIp = normalizeInput(publicIp).trim
  normalizedLanIp = normalizeInput(lanIp).trim
  normalizedGatewayIp = normalizeInput(gatewayIp).trim
  normalizedRole = normalizeInput(roleText).trim
  normalizedSource = normalizeInput(sourceText).trim

  if normalizedRole == "" then normalizedRole = "host"
  if normalizedSource == "" then normalizedSource = "discovery"
  if normalizedPublicIp == "" and not is_lan_ip(hostIp) then normalizedPublicIp = hostIp
  if normalizedLanIp == "" and is_lan_ip(hostIp) then normalizedLanIp = hostIp
  if priorityText == "" then priorityText = priorityLabel(scoreValue)

  return {
    "ip": hostIp,
    "public_ip": normalizedPublicIp,
    "lan_ip": normalizedLanIp,
    "gateway_ip": normalizedGatewayIp,
    "role": normalizedRole,
    "priority": normalizeInput(priorityText).trim.lower,
    "score": scoreValue,
    "open_ports": openPorts,
    "source": normalizedSource,
  }
end function

addUniqueHostRecord = function(hostRecords, seen, hostRecord)
  if hostRecord == null then return 0

  hostKey = normalizeInput(hostRecord.ip).trim
  if hostKey == "" then return 0
  if listHasValue(seen, hostKey) then return 0

  seen.push(hostKey)
  hostRecords.push(hostRecord)
  return 1
end function

formatOpenPorts = function(openPorts)
  if openPorts == null or openPorts.len == 0 then return "none"

  parts = []
  for portInfo in openPorts
    if portInfo == null then continue
    parts.push(portInfo.port + " (" + serviceName(portInfo.port) + ")")
  end for

  if parts.len == 0 then return "none"
  return parts.join(", ")
end function

formatPortNumbers = function(openPorts)
  if openPorts == null or openPorts.len == 0 then return "none"

  parts = []
  for portInfo in openPorts
    if portInfo == null then continue
    parts.push("" + portInfo.port)
  end for

  if parts.len == 0 then return "none"
  return parts.join(",")
end function

routerHasLanIp = function(router, ipAddress)
  if router == null then return 0
  wantedIp = normalizeInput(ipAddress).trim
  if wantedIp == "" then return 0
  if normalizeInput(router.local_ip).trim == wantedIp then return 1

  lanIps = router.devices_lan_ip
  if lanIps == null then return 0

  for lanIp in lanIps
    if normalizeInput(lanIp).trim == wantedIp then return 1
  end for

  return 0
end function

buildRouterSelfRecord = function(router, usePublicIp = 1, sourceText = "router-discovery")
  if router == null then return null

  primaryIp = normalizeInput(router.local_ip).trim
  if usePublicIp and normalizeInput(router.public_ip).trim != "" then primaryIp = normalizeInput(router.public_ip).trim

  openPorts = collectRouterEntryPorts(router)
  scoreValue = scoreHost(primaryIp, openPorts) + 3
  return makeHostRecord(primaryIp, "gateway", priorityLabel(scoreValue), scoreValue, openPorts, sourceText, normalizeInput(router.public_ip).trim, normalizeInput(router.local_ip).trim, normalizeInput(router.local_ip).trim)
end function

buildRouterHostRecords = function(router, preferredIp = "", usePublicEntry = 1, sourceText = "router-discovery")
  hostRecords = []
  seen = []
  if router == null then return hostRecords

  addUniqueHostRecord(hostRecords, seen, buildRouterSelfRecord(router, usePublicEntry, sourceText))

  lanIps = router.devices_lan_ip
  if lanIps != null then
    for lanIp in lanIps
      openPorts = collectOpenPorts(router, lanIp)
      scoreValue = scoreHost(lanIp, openPorts)
      roleText = hostRoleGuess(lanIp, openPorts)
      addUniqueHostRecord(hostRecords, seen, makeHostRecord(lanIp, roleText, priorityLabel(scoreValue), scoreValue, openPorts, sourceText, normalizeInput(router.public_ip).trim, normalizeInput(lanIp).trim, normalizeInput(router.local_ip).trim))
    end for
  end if

  return hostRecords
end function

parseHostPortsText = function(textValue)
  openPorts = []
  seen = []
  cleanText = normalizeInput(textValue).trim
  if cleanText == "" or cleanText.lower == "none" then return openPorts

  for rawPart in cleanText.split(",")
    part = normalizeInput(rawPart).trim
    if part == "" then continue

    portText = part
    if part.indexOf(" ") != null then portText = part.split(" ")[0]
    if not isNumericText(portText) then continue

    pushOpenPort(openPorts, seen, portText.val)
  end for

  return openPorts
end function

parseMapperHostLine = function(lineText)
  cleanLine = normalizeInput(lineText).trim
  if cleanLine == "" then return null

  if cleanLine.indexOf("|") == null then return null
  parts = cleanLine.split("|")
  if parts == null or parts.len < 2 then return null

  ipAddress = normalizeInput(parts[0]).trim
  if not isValidIpAddress(ipAddress) then return null

  roleText = normalizeInput(parts[1]).trim
  priorityText = ""
  scoreValue = 0
  portsText = "none"

  for part in parts
    cleanedPart = normalizeInput(part).trim
    lowered = cleanedPart.lower
    if cleanedPart == "" then continue
    if cleanedPart == ipAddress then continue
    if cleanedPart == roleText then continue
    if lowered.indexOf("priority=") == 0 then priorityText = cleanedPart.split("=")[1]
    if lowered.indexOf("score=") == 0 then
      scoreText = cleanedPart.split("=")[1]
      if isNumericText(scoreText) then scoreValue = scoreText.val
      continue
    end if
    portsText = cleanedPart
  end for

  openPorts = parseHostPortsText(portsText)
  if scoreValue == 0 then scoreValue = scoreHost(ipAddress, openPorts)
  if priorityText == "" then priorityText = priorityLabel(scoreValue)
  return makeHostRecord(ipAddress, roleText, priorityText, scoreValue, openPorts, "mapper-file")
end function

loadMapperHostRecords = function(computer, mapperFilePath)
  hostRecords = []
  seen = []
  normalizedPath = normalizeInput(mapperFilePath).trim
  if normalizedPath == "" then return hostRecords

  mapperFile = computer.File(normalizedPath)
  mapperContent = readTextFile(mapperFile)
  if mapperContent == null or mapperContent == "" then return hostRecords

  for line in mapperContent.split(NL)
    hostRecord = parseMapperHostLine(line)
    addUniqueHostRecord(hostRecords, seen, hostRecord)
  end for

  return hostRecords
end function

discoverTargets = function(targetContext, runtimeContext, runState)
  discoveredHosts = []
  seen = []

  mappedHosts = loadMapperHostRecords(runtimeContext.computer, runState.config.mapper_file)
  for mappedHost in mappedHosts
    addUniqueHostRecord(discoveredHosts, seen, mappedHost)
  end for

  if targetContext.entry_type == "public_ip" then
    targetRouter = get_router(targetContext.entry_ip)
    if targetRouter != null then
      for hostRecord in buildRouterHostRecords(targetRouter, targetContext.target_lan_ip, 1, "public-router")
        addUniqueHostRecord(discoveredHosts, seen, hostRecord)
      end for
    else
      addUniqueHostRecord(discoveredHosts, seen, makeHostRecord(targetContext.entry_ip, "public-host", "medium", 4, [], "public-fallback"))
    end if
  else
    if targetContext.entry_type == "router_ip" then
      targetRouter = null
      if runtimeContext.current_router != null and routerHasLanIp(runtimeContext.current_router, targetContext.entry_ip) then
        targetRouter = runtimeContext.current_router
      end if

      if targetRouter == null and not is_lan_ip(targetContext.entry_ip) then
        targetRouter = get_router(targetContext.entry_ip)
      end if

      if targetRouter != null then
        for hostRecord in buildRouterHostRecords(targetRouter, targetContext.target_lan_ip, 0, "router-target")
          addUniqueHostRecord(discoveredHosts, seen, hostRecord)
        end for
      else
        fallbackScore = scoreHost(targetContext.entry_ip, []) + 3
        addUniqueHostRecord(discoveredHosts, seen, makeHostRecord(targetContext.entry_ip, "gateway", priorityLabel(fallbackScore), fallbackScore, [], "router-fallback", "", targetContext.entry_ip, targetContext.entry_ip))
      end if
    else
      if targetContext.entry_type == "lan_ip" then
        if runtimeContext.current_router != null and routerHasLanIp(runtimeContext.current_router, targetContext.entry_ip) then
          for hostRecord in buildRouterHostRecords(runtimeContext.current_router, targetContext.entry_ip, 0, "current-router")
            addUniqueHostRecord(discoveredHosts, seen, hostRecord)
          end for
        else
          addUniqueHostRecord(discoveredHosts, seen, makeHostRecord(targetContext.entry_ip, "host", "medium", scoreHost(targetContext.entry_ip, []), [], "lan-direct"))
        end if
      else
        if runtimeContext.current_router != null then
          for hostRecord in buildRouterHostRecords(runtimeContext.current_router, runtimeContext.computer.local_ip, 0, "current-router")
            addUniqueHostRecord(discoveredHosts, seen, hostRecord)
          end for
        else
          addUniqueHostRecord(discoveredHosts, seen, makeHostRecord(runtimeContext.computer.local_ip, "host", "medium", 1, [], "current-host", normalizeInput(runtimeContext.computer.public_ip).trim, normalizeInput(runtimeContext.computer.local_ip).trim))
        end if
      end if
    end if
  end if

  runState.discovered_hosts = discoveredHosts
  return discoveredHosts
end function

hostPriorityScore = function(hostRecord, targetContext, runState = null)
  if hostRecord == null then return -999999

  scoreValue = hostRecord.score * 10
  roleText = normalizeInput(hostRecord.role).trim.lower
  workerMode = 0
  currentHostPublicIp = ""
  currentHostLocalIp = ""
  currentRouterPublicIp = ""
  currentRouterLocalIp = ""

  if runState != null and runState.config != null then
    if normalizeInput(runState.config.mode).trim == "worker" then workerMode = 1
  end if

  if runState != null and runState.runtime != null and runState.runtime.computer != null then
    currentHostPublicIp = normalizeInput(runState.runtime.computer.public_ip).trim
    currentHostLocalIp = normalizeInput(runState.runtime.computer.local_ip).trim
  end if

  if runState != null and runState.runtime != null and runState.runtime.current_router != null then
    currentRouterPublicIp = normalizeInput(runState.runtime.current_router.public_ip).trim
    currentRouterLocalIp = normalizeInput(runState.runtime.current_router.local_ip).trim
  end if

  if normalizeInput(hostRecord.priority) == "high" then scoreValue = scoreValue + 20
  if roleText.indexOf("gateway") != null then scoreValue = scoreValue + 15
  if roleText == "smartphone" then scoreValue = scoreValue - 10

  if not workerMode and targetContext.entry_type == "public_ip" and targetContext.target_lan_ip == "" then
    if hostRecord.ip == targetContext.entry_ip then scoreValue = scoreValue + 120
    if normalizeInput(hostRecord.public_ip).trim == targetContext.entry_ip then scoreValue = scoreValue + 80
  end if

  if targetContext.entry_type == "router_ip" and hostRecord.ip == targetContext.entry_ip then scoreValue = scoreValue + 140
  if not workerMode and targetContext.target_ip != "" and (hostRecord.ip == targetContext.target_ip or normalizeInput(hostRecord.public_ip).trim == targetContext.target_ip) then scoreValue = scoreValue + 120
  if targetContext.target_lan_ip != "" and (hostRecord.ip == targetContext.target_lan_ip or normalizeInput(hostRecord.lan_ip).trim == targetContext.target_lan_ip) then scoreValue = scoreValue + 200

  if workerMode then
    if currentHostLocalIp != "" and (hostRecord.ip == currentHostLocalIp or normalizeInput(hostRecord.lan_ip).trim == currentHostLocalIp) then scoreValue = scoreValue - 300
    if currentHostLocalIp == "" and currentHostPublicIp != "" and normalizeInput(hostRecord.public_ip).trim == currentHostPublicIp then scoreValue = scoreValue - 300
    if currentRouterPublicIp != "" and normalizeInput(hostRecord.ip).trim == currentRouterPublicIp then scoreValue = scoreValue - 260
    if currentRouterPublicIp != "" and currentRouterLocalIp != "" and normalizeInput(hostRecord.public_ip).trim == currentRouterPublicIp and normalizeInput(hostRecord.lan_ip).trim == currentRouterLocalIp then scoreValue = scoreValue - 260
  end if

  return scoreValue
end function

rankTargets = function(hostRecords, targetContext, runState)
  rankedHosts = []
  used = []
  if hostRecords == null then return rankedHosts

  while used.len < hostRecords.len
    yield
    bestHost = null
    bestKey = ""
    bestScore = -999999

    for hostRecord in hostRecords
      if hostRecord == null then continue
      hostKey = normalizeInput(hostRecord.ip).trim
      if hostKey == "" then continue
      if listHasValue(used, hostKey) then continue

      hostScore = hostPriorityScore(hostRecord, targetContext, runState)
      if bestHost == null or hostScore > bestScore then
        bestHost = hostRecord
        bestKey = hostKey
        bestScore = hostScore
      else
        if hostScore == bestScore and hostRecord.ip < bestHost.ip then
          bestHost = hostRecord
          bestKey = hostKey
          bestScore = hostScore
        end if
      end if
    end for

    if bestHost == null then break
    used.push(bestKey)
    rankedHosts.push(bestHost)
  end while

  runState.ranked_hosts = rankedHosts
  return rankedHosts
end function

promptTargetHostMenu = function(hostRecords, targetContext, runConfig, runState)
  if runConfig.non_interactive then return ""
  if hostRecords == null or hostRecords.len <= 1 then return ""
  if targetContext.target_lan_ip != "" then return targetContext.target_lan_ip

  print("CRS target host menu")
  hostIndex = 1
  for hostRecord in hostRecords
    print("" + hostIndex + ". " + hostRecord.ip + " | " + hostRecord.role + " | priority=" + hostRecord.priority + " | score=" + hostRecord.score + " | " + formatOpenPorts(hostRecord.open_ports))
    hostIndex = hostIndex + 1
  end for

  selectedInput = normalizeInput(user_input("Target host [1-" + hostRecords.len + ", blank=auto]: ")).trim
  if selectedInput == "" then return ""
  if not isNumericText(selectedInput) then return ""

  selectedIndex = selectedInput.val - 1
  if selectedIndex < 0 or selectedIndex >= hostRecords.len then return ""

  runState.selected_host_ip = hostRecords[selectedIndex].ip
  return hostRecords[selectedIndex].ip
end function

findHostRecordByIp = function(hostRecords, wantedIp)
  normalizedWantedIp = normalizeInput(wantedIp).trim
  if normalizedWantedIp == "" then return null
  if hostRecords == null then return null

  for hostRecord in hostRecords
    if hostRecord == null then continue
    if normalizeInput(hostRecord.ip).trim == normalizedWantedIp then return hostRecord
  end for

  return null
end function

findExactTargetHostRecord = function(hostRecords, targetContext)
  if hostRecords == null then return null
  if targetContext == null then return null

  targetLanIp = normalizeInput(targetContext.target_lan_ip).trim
  if targetLanIp != "" then
    targetRecord = findHostRecordByIp(hostRecords, targetLanIp)
    if targetRecord != null then return targetRecord

    for hostRecord in hostRecords
      if hostRecord == null then continue
      if normalizeInput(hostRecord.lan_ip).trim == targetLanIp then return hostRecord
    end for
  end if

  targetIp = normalizeInput(targetContext.target_ip).trim
  if targetIp != "" then
    targetRecord = findHostRecordByIp(hostRecords, targetIp)
    if targetRecord != null then return targetRecord

    for hostRecord in hostRecords
      if hostRecord == null then continue
      if normalizeInput(hostRecord.public_ip).trim == targetIp then return hostRecord
    end for
  end if

  return null
end function

findPreferredEntryHostRecord = function(hostRecords, targetContext)
  if hostRecords == null then return null
  if targetContext == null then return null
  if not targetContext.exact_internal_target then return null
  if normalizeInput(targetContext.entry_type).trim.lower != "public_ip" then return null

  targetPublicIp = normalizeInput(targetContext.target_ip).trim
  gatewayFallback = null

  for hostRecord in hostRecords
    if hostRecord == null then continue

    roleText = normalizeInput(hostRecord.role).trim.lower
    if roleText.indexOf("gateway") == null then continue
    if gatewayFallback == null then gatewayFallback = hostRecord

    hostIp = normalizeInput(hostRecord.ip).trim
    hostPublicIp = normalizeInput(hostRecord.public_ip).trim
    if targetPublicIp != "" and (hostIp == targetPublicIp or hostPublicIp == targetPublicIp) then return hostRecord
  end for

  return gatewayFallback
end function

isExactTargetHost = function(runState, targetRecord)
  if runState == null then return 0
  if targetRecord == null then return 0

  exactTargetRecord = findExactTargetHostRecord(runState.ranked_hosts, runState.target)
  if exactTargetRecord == null then return 0

  return normalizeInput(exactTargetRecord.ip).trim == normalizeInput(targetRecord.ip).trim
end function

saveHostCache = function(hostCacheFile, hostRecords)
  if hostCacheFile == null then return "Missing host cache file"

  lines = ["ip" + TAB + "public_ip" + TAB + "lan_ip" + TAB + "gateway_ip" + TAB + "role" + TAB + "priority" + TAB + "score" + TAB + "ports" + TAB + "source"]
  if hostRecords != null then
    for hostRecord in hostRecords
      if hostRecord == null then continue
      appendLine(lines, hostRecord.ip + TAB + normalizeInput(hostRecord.public_ip).trim + TAB + normalizeInput(hostRecord.lan_ip).trim + TAB + normalizeInput(hostRecord.gateway_ip).trim + TAB + hostRecord.role + TAB + hostRecord.priority + TAB + hostRecord.score + TAB + formatPortNumbers(hostRecord.open_ports) + TAB + hostRecord.source)
    end for
  end if

  return hostCacheFile.set_content(lines.join(NL))
end function

writeDiscoveryReport = function(runtimeContext, runConfig, targetContext, outputFiles, discoveredHosts, rankedHosts, selectedHostIp = "", attackResult = null, credentialResult = null, finalResult = null)
  reportLines = []
  appendLine(reportLines, "CRS V1 startup report")
  appendLine(reportLines, "====================")
  appendLine(reportLines, "")

  startupRows = buildStartupSummaryLines(runtimeContext, runConfig, targetContext, outputFiles)
  for row in startupRows
    parts = row.split(TAB)
    if parts != null and parts.len >= 2 then
      appendLine(reportLines, parts[0] + ": " + parts[1])
    else
      appendLine(reportLines, row)
    end if
  end for

  appendLine(reportLines, "")
  appendLine(reportLines, "Discovery")
  appendLine(reportLines, "=========")
  appendLine(reportLines, "Discovered hosts: " + discoveredHosts.len)
  appendLine(reportLines, "Ranked hosts: " + rankedHosts.len)
  appendLine(reportLines, "Selected host: " + formatValueDisplay(selectedHostIp))
  appendLine(reportLines, "")

  if rankedHosts != null and rankedHosts.len > 0 then
    for hostRecord in rankedHosts
      appendLine(reportLines, hostRecord.ip + " | " + hostRecord.role + " | priority=" + hostRecord.priority + " | score=" + hostRecord.score + " | " + formatOpenPorts(hostRecord.open_ports))
    end for
  else
    appendLine(reportLines, "No hosts discovered.")
  end if

  if attackResult != null then
    appendLine(reportLines, "")
    appendLine(reportLines, "Attack")
    appendLine(reportLines, "======")
    appendLine(reportLines, "Status: " + formatValueDisplay(attackResult.status))
    appendLine(reportLines, "Target: " + formatValueDisplay(attackResult.target_ip))
    appendLine(reportLines, "Ports tried: " + formatValueDisplay(attackResult.ports_tried_text))
    appendLine(reportLines, "Sessions opened: " + attackResult.sessions_opened)
    appendLine(reportLines, "Overflow attempts: " + attackResult.overflow_attempts)
    appendLine(reportLines, "Memory zones seen: " + attackResult.memory_zones)
    appendLine(reportLines, "Library: " + formatValueDisplay(attackResult.lib_name) + " v" + formatValueDisplay(attackResult.lib_version))
    appendLine(reportLines, "Exploit result type: " + formatValueDisplay(attackResult.raw_result_type))
    appendLine(reportLines, "Result type: " + formatValueDisplay(attackResult.result_type))
    appendLine(reportLines, "Escalation status: " + formatValueDisplay(attackResult.escalation_status))
    appendLine(reportLines, "Surface records: " + formatValueDisplay(attackResult.surface_records))
    appendLine(reportLines, "Manual assist: " + formatValueDisplay(attackResult.manual_assist_status))
    appendLine(reportLines, "Manual port: " + formatValueDisplay(attackResult.manual_assist_port))
    appendLine(reportLines, "Manual memory: " + formatValueDisplay(attackResult.manual_assist_memory))
    appendLine(reportLines, "Manual unsafe: " + formatValueDisplay(attackResult.manual_assist_unsafe))
    appendLine(reportLines, "Success port: " + formatValueDisplay(attackResult.success_port))
    appendLine(reportLines, "Success memory: " + formatValueDisplay(attackResult.success_memory))
    appendLine(reportLines, "Success unsafe: " + formatValueDisplay(attackResult.success_unsafe))
    appendLine(reportLines, "")

    if attackResult.notes != null and attackResult.notes.len > 0 then
      for noteLine in attackResult.notes
        appendLine(reportLines, noteLine)
      end for
    else
      appendLine(reportLines, "No attack notes recorded.")
    end if
  end if

  if credentialResult != null then
    appendLine(reportLines, "")
    appendLine(reportLines, "Credentials")
    appendLine(reportLines, "===========")
    appendLine(reportLines, "Status: " + formatValueDisplay(credentialResult.status))
    appendLine(reportLines, "Source host: " + formatValueDisplay(credentialResult.source_host))
    appendLine(reportLines, "Attempts: " + credentialResult.attempts)
    appendLine(reportLines, "Successes: " + credentialResult.successes)
    appendLine(reportLines, "Password candidates: " + credentialResult.password_candidates)
    appendLine(reportLines, "Files scanned: " + credentialResult.scanned_files)
    appendLine(reportLines, "Loot records: " + formatValueDisplay(credentialResult.loot_records))
    appendLine(reportLines, "Credential host: " + formatValueDisplay(credentialResult.host_ip))
    appendLine(reportLines, "Credential user: " + formatValueDisplay(credentialResult.user))
    appendLine(reportLines, "")

    if credentialResult.notes != null and credentialResult.notes.len > 0 then
      for noteLine in credentialResult.notes
        appendLine(reportLines, noteLine)
      end for
    else
      appendLine(reportLines, "No credential notes recorded.")
    end if
  end if

  if finalResult != null then
    appendLine(reportLines, "")
    appendLine(reportLines, "Final")
    appendLine(reportLines, "=====")
    appendLine(reportLines, "Status: " + formatValueDisplay(finalResult.status))
    appendLine(reportLines, "Accepted type: " + formatValueDisplay(finalResult.accepted_type))
    appendLine(reportLines, "Accepted access level: " + formatValueDisplay(finalResult.accepted_access_level))
    appendLine(reportLines, "Accepted host: " + formatValueDisplay(finalResult.accepted_host))
    appendLine(reportLines, "Explorer status: " + formatValueDisplay(finalResult.explorer_status))
    appendLine(reportLines, "Handoff status: " + formatValueDisplay(finalResult.handoff_status))
    appendLine(reportLines, "Stage status: " + formatValueDisplay(finalResult.stage_status))
    appendLine(reportLines, "Local recon status: " + formatValueDisplay(finalResult.local_recon_status))
    appendLine(reportLines, "Local next hop: " + formatValueDisplay(finalResult.local_recon_next_hop))
    appendLine(reportLines, "Mission action: " + formatValueDisplay(finalResult.mission_action_status))
    appendLine(reportLines, "Loot status: " + formatValueDisplay(finalResult.loot_status))
    appendLine(reportLines, "Cleanup status: " + formatValueDisplay(finalResult.cleanup_status))
    appendLine(reportLines, "")

    if finalResult.notes != null and finalResult.notes.len > 0 then
      for noteLine in finalResult.notes
        appendLine(reportLines, noteLine)
      end for
    else
      appendLine(reportLines, "No final notes recorded.")
    end if
  end if

  return outputFiles.report_file.set_content(reportLines.join(NL))
end function

printDiscoverySummary = function(rankedHosts, selectedHostIp = "")
  print("CRS V1 discovery summary")
  if rankedHosts == null or rankedHosts.len == 0 then
    print("No hosts discovered.")
    print("")
    return
  end if

  hostIndex = 1
  for hostRecord in rankedHosts
    print("" + hostIndex + ". " + hostRecord.ip + " | " + hostRecord.role + " | priority=" + hostRecord.priority + " | score=" + hostRecord.score + " | " + formatOpenPorts(hostRecord.open_ports))
    hostIndex = hostIndex + 1
  end for

  print("Selected host: " + formatValueDisplay(selectedHostIp))
  print("")
end function

buildAttackPortTargets = function(targetRecord)
  ports = []
  seen = []
  if targetRecord == null then return ports

  roleText = normalizeInput(targetRecord.role).trim.lower
  if roleText.indexOf("gateway") != null then
    seen.push("0")
    ports.push(0)
  end if

  if targetRecord.open_ports == null then return ports

  for portInfo in targetRecord.open_ports
    if portInfo == null then continue
    portNumber = portInfo.port
    portKey = "" + portNumber
    if listHasValue(seen, portKey) then continue
    seen.push(portKey)
    ports.push(portNumber)
  end for

  return ports
end function

runOverflow = function(metaLib, portNumber, routerLanIp, memoryAddress, unsafeValue)
  return metaLib.overflow(memoryAddress, unsafeValue)
end function

resolveRouterPivotLanIp = function(runState, targetRecord)
  if runState != null and runState.target != null then
    targetLanIp = normalizeInput(runState.target.target_lan_ip).trim
    if targetLanIp != "" then return targetLanIp
  end if

  return ""
end function

buildOverflowVariants = function(runState, targetRecord, portNumber)
  variants = []
  if portNumber != 0 then
    variants.push({"label":"default", "extra_arg":""})
    return variants
  end if

  variants.push({"label":"router-self", "extra_arg":""})
  pivotLanIp = resolveRouterPivotLanIp(runState, targetRecord)
  if pivotLanIp != "" then variants.push({"label":"lan-pivot", "extra_arg":pivotLanIp})
  return variants
end function

buildOverflowTryKey = function(memoryAddress, unsafeValue, variantLabel, extraArg = "")
  return normalizeInput(memoryAddress).trim + TAB + normalizeInput(unsafeValue).trim + TAB + normalizeCacheField(variantLabel) + TAB + normalizeCacheField(extraArg)
end function

runOverflowVariant = function(metaLib, memoryAddress, unsafeValue, extraArg = "")
  extraText = normalizeInput(extraArg).trim
  if extraText != "" then return metaLib.overflow(memoryAddress, unsafeValue, extraText)
  return metaLib.overflow(memoryAddress, unsafeValue)
end function

classifyAttackStatus = function(resultType, resultValue = null)
  if resultType == "shell" then return "shell"
  if resultType == "computer" then return "computer"
  if resultType == "file" then return "file"
  if resultType == "number" then
    if resultValue == 1 then return "numeric-hit"
    return "numeric-nohit"
  end if
  if resultType == "string" then
    cleanText = normalizeInput(resultValue).trim
    if cleanText == "" then return "string-empty"
    return "string-hit"
  end if
  if resultType == "" then return "no-hit"
  return "other-hit"
end function

isAcceptedAttackResult = function(resultType, resultValue = null)
  statusText = classifyAttackStatus(resultType, resultValue)
  if statusText == "shell" then return 1
  return 0
end function

resolveAttackAddress = function(targetRecord, portNumber)
  if targetRecord == null then return ""

  if portNumber == 0 then
    publicIp = normalizeInput(targetRecord.public_ip).trim
    if publicIp != "" then return publicIp
  end if

  return normalizeInput(targetRecord.ip).trim
end function

printAttackSummary = function(attackResult)
  if attackResult == null then return

  print("CRS V1 attack summary")
  print("Status: " + formatValueDisplay(attackResult.status))
  print("Target: " + formatValueDisplay(attackResult.target_ip))
  print("Ports tried: " + formatValueDisplay(attackResult.ports_tried_text))
  print("Sessions opened: " + attackResult.sessions_opened)
  print("Overflow attempts: " + attackResult.overflow_attempts)
  print("Memory zones seen: " + attackResult.memory_zones)
  print("Library: " + formatValueDisplay(attackResult.lib_name) + " v" + formatValueDisplay(attackResult.lib_version))
  print("Exploit result type: " + formatValueDisplay(attackResult.raw_result_type))
  print("Result type: " + formatValueDisplay(attackResult.result_type))
  print("Escalation status: " + formatValueDisplay(attackResult.escalation_status))
  if normalizeInput(attackResult.manual_assist_status).trim != "" then print("Manual assist: " + attackResult.manual_assist_status)
  if normalizeInput(attackResult.manual_assist_port).trim != "" then print("Manual port: " + attackResult.manual_assist_port)
  if normalizeInput(attackResult.manual_assist_memory).trim != "" then print("Manual memory: " + attackResult.manual_assist_memory)
  if normalizeInput(attackResult.manual_assist_unsafe).trim != "" then print("Manual unsafe: " + attackResult.manual_assist_unsafe)
  if attackResult.success_port != "" then print("Success port: " + attackResult.success_port)
  if attackResult.success_memory != "" then print("Success memory: " + attackResult.success_memory)
  if attackResult.success_unsafe != "" then print("Success unsafe: " + attackResult.success_unsafe)
  print("")
end function

buildAttackQueue = function(rankedHosts, selectedHostRecord, runState = null)
  queue = []
  seen = []

  preferredEntryRecord = null
  if runState != null and selectedHostRecord != null then
    if isExactTargetHost(runState, selectedHostRecord) then
      preferredEntryRecord = findPreferredEntryHostRecord(rankedHosts, runState.target)
    end if
  end if

  if preferredEntryRecord != null then
    addUniqueHostRecord(queue, seen, preferredEntryRecord)
  end if

  if selectedHostRecord != null then
    addUniqueHostRecord(queue, seen, selectedHostRecord)
  end if

  if rankedHosts == null then return queue

  for hostRecord in rankedHosts
    addUniqueHostRecord(queue, seen, hostRecord)
  end for

  return queue
end function

shouldPromptBeforeNextHost = function(runState, hostRecord, remainingCount)
  if runState == null then return 0
  if runState.config == null then return 0
  if runState.config.non_interactive then return 0
  if remainingCount <= 0 then return 0
  if hostRecord == null then return 0

  roleText = normalizeInput(hostRecord.role).trim.lower
  if roleText.indexOf("gateway") != null then return 0
  return 1
end function

isExactTargetShellResult = function(runState, hostRecord, attackResult)
  if runState == null then return 0
  if hostRecord == null then return 0
  if attackResult == null then return 0

  exactTargetRecord = findExactTargetHostRecord(runState.ranked_hosts, runState.target)
  if exactTargetRecord == null then return 0
  if normalizeInput(exactTargetRecord.ip).trim != normalizeInput(hostRecord.ip).trim then return 0

  rawType = normalizeInput(attackResult.raw_result_type).trim.lower
  resultType = normalizeInput(attackResult.result_type).trim.lower
  statusText = normalizeInput(attackResult.status).trim.lower

  if rawType == "shell" then return 1
  if resultType == "shell" then return 1
  if statusText == "root-shell" or statusText == "persistence-shell" or statusText == "final-shell" then return 1
  return 0
end function

confirmContinueAfterShell = function(runState, hostRecord, remainingCount)
  if not shouldPromptBeforeNextHost(runState, hostRecord, remainingCount) then return 0

  promptText = "Shell obtained on " + normalizeInput(hostRecord.ip).trim + " (" + normalizeInput(hostRecord.role).trim + "). Continue to next host? [y/N]: "
  answer = normalizeInput(user_input(promptText)).trim.lower
  return toYesNoFlag(answer, 0)
end function

attackRankedTargets = function(rankedHosts, selectedHostRecord, runtimeContext, runState)
  queue = buildAttackQueue(rankedHosts, selectedHostRecord, runState)
  bestResult = null
  bestPriority = -1
  queueIndex = -1

  for hostRecord in queue
    yield
    queueIndex = queueIndex + 1
    if hostRecord == null then continue

    currentResult = attackTarget(hostRecord, runtimeContext, runState)
    if currentResult == null then continue

    currentPriority = 0
    if currentResult.status == "computer" then currentPriority = 3
    if currentResult.status == "final-shell" or currentResult.status == "root-shell" or currentResult.status == "persistence-shell" then currentPriority = 5
    if currentResult.result != null and isAcceptedAttackResult(currentResult.raw_result_type, currentResult.result) then currentPriority = 4
    if currentResult.result != null and currentPriority == 0 then currentPriority = 2
    if currentResult.status != "no-hit" and currentPriority == 0 then currentPriority = 1

    if currentPriority > bestPriority then
      bestPriority = currentPriority
      bestResult = currentResult
    end if

    printAttackSummary(currentResult)
    if isExactTargetShellResult(runState, hostRecord, currentResult) then
      appendLine(currentResult.notes, "Exact target shell obtained; stopping lateral movement and keeping focus on same-host escalation.")
      return currentResult
    end if

    if hasRecordedShellAccess(runState) then
      remainingCount = queue.len - queueIndex - 1
      hasShellResult = 0
      if currentResult.raw_result_type == "shell" then hasShellResult = 1
      if currentResult.result_type == "shell" then hasShellResult = 1
      if currentResult.status == "root-shell" or currentResult.status == "persistence-shell" or currentResult.status == "final-shell" then hasShellResult = 1

      if hasShellResult and confirmContinueAfterShell(runState, hostRecord, remainingCount) then
        continue
      end if

      if hasShellResult then return currentResult
      continue
    end if
  end for

  if bestResult != null then return bestResult
  return {
    "status": "no-hit",
    "result": null,
    "raw_result_type": "",
    "result_type": "",
    "escalation_status": "",
    "manual_assist_status": "",
    "manual_assist_port": "",
    "manual_assist_memory": "",
    "manual_assist_unsafe": "",
    "target_ip": "",
    "ports_tried": [],
    "ports_tried_text": "",
    "sessions_opened": 0,
    "overflow_attempts": 0,
    "memory_zones": 0,
    "surface_records": 0,
    "lib_name": "",
    "lib_version": "",
    "success_port": "",
    "success_memory": "",
    "success_unsafe": "",
    "notes": [],
  }
end function

attackTarget = function(targetRecord, runtimeContext, runState)
  outcome = {
    "status": "not-run",
    "result": null,
    "raw_result_type": "",
    "result_type": "",
    "escalation_status": "",
    "manual_assist_status": "",
    "manual_assist_port": "",
    "manual_assist_memory": "",
    "manual_assist_unsafe": "",
    "target_ip": "",
    "ports_tried": [],
    "ports_tried_text": "",
    "sessions_opened": 0,
    "overflow_attempts": 0,
    "memory_zones": 0,
    "surface_records": 0,
    "lib_name": "",
    "lib_version": "",
    "success_port": "",
    "success_memory": "",
    "success_unsafe": "",
    "notes": [],
  }

  if targetRecord == null then
    outcome.status = "no-target"
    return outcome
  end if

  outcome.target_ip = normalizeInput(targetRecord.ip).trim

  if runtimeContext.meta == null then
    outcome.status = "missing-metaxploit"
    appendLine(outcome.notes, "Metaxploit library is not loaded.")
    return outcome
  end if

  targetPorts = buildAttackPortTargets(targetRecord)
  if targetPorts.len == 0 then
    outcome.status = "no-ports"
    appendLine(outcome.notes, "No attackable ports were discovered for the selected host.")
    return outcome
  end if

  signatureCache = runState.signature_cache
  triedSignatures = []
  maxAttempts = 120
  exactTargetMode = isExactTargetHost(runState, targetRecord)
  fallbackComputerResult = null
  fallbackComputerPort = ""
  fallbackComputerMemory = ""
  fallbackComputerUnsafe = ""
  fallbackComputerEscalationStatus = ""
  fallbackFileResult = null
  fallbackFileStatus = ""
  fallbackFilePriority = -1
  fallbackFilePort = ""
  fallbackFileMemory = ""
  fallbackFileUnsafe = ""
  fallbackShellResult = null
  fallbackShellResultType = ""
  fallbackShellStatus = ""
  fallbackShellAccessLevel = ""
  fallbackShellPort = ""
  fallbackShellMemory = ""
  fallbackShellUnsafe = ""

  for portNumber in targetPorts
    yield
    attackAddress = resolveAttackAddress(targetRecord, portNumber)
    if attackAddress == "" then continue
    outcome.ports_tried.push("" + portNumber)

    if portNumber == 0 then
      session = runtimeContext.meta.net_use(attackAddress)
    else
      session = runtimeContext.meta.net_use(attackAddress, portNumber)
    end if

    if session == null then
      appendLine(outcome.notes, "Session failed on " + attackAddress + ":" + portNumber)
      continue
    end if

    outcome.sessions_opened = outcome.sessions_opened + 1
    appendLine(outcome.notes, "Session opened on " + attackAddress + ":" + portNumber)

    remoteLib = session.dump_lib
    if remoteLib == null then
      appendLine(outcome.notes, "Library dump failed on " + attackAddress + ":" + portNumber)
      continue
    end if

    outcome.lib_name = normalizeInput(remoteLib.lib_name).trim
    outcome.lib_version = normalizeInput(remoteLib.version).trim
    appendLine(outcome.notes, "Library " + outcome.lib_name + " v" + outcome.lib_version)

    cachedSignatures = findCachedSignatures(signatureCache, outcome.lib_name, outcome.lib_version, portNumber)
    for cachedEntry in cachedSignatures
      yield
      if outcome.overflow_attempts >= maxAttempts then
        outcome.status = "attempt-limit"
        appendLine(outcome.notes, "Attack attempt limit reached while replaying cached signatures.")
        outcome.ports_tried_text = outcome.ports_tried.join(", ")
        return outcome
      end if

      overflowVariants = buildOverflowVariants(runState, targetRecord, portNumber)
      for overflowVariant in overflowVariants
        yield
        if outcome.overflow_attempts >= maxAttempts then
          outcome.status = "attempt-limit"
          appendLine(outcome.notes, "Attack attempt limit reached while replaying cached signatures.")
          outcome.ports_tried_text = outcome.ports_tried.join(", ")
          return outcome
        end if

        variantLabel = normalizeInput(overflowVariant.label).trim
        variantExtraArg = normalizeInput(overflowVariant.extra_arg).trim
        cachedTryKey = buildOverflowTryKey(cachedEntry.memory, cachedEntry.unsafe, variantLabel, variantExtraArg)
        if listHasValue(triedSignatures, cachedTryKey) then continue

        triedSignatures.push(cachedTryKey)
        outcome.overflow_attempts = outcome.overflow_attempts + 1
        result = runOverflowVariant(remoteLib, cachedEntry.memory, cachedEntry.unsafe, variantExtraArg)
        if result == null then continue

        resultType = typeof(result)
        addSignatureCacheRecord(signatureCache, outcome.lib_name, outcome.lib_version, portNumber, cachedEntry.memory, cachedEntry.unsafe, resultType)
        outcome.result = result
        outcome.raw_result_type = resultType
        outcome.result_type = resultType
        outcome.status = classifyAttackStatus(resultType, result)
        outcome.success_port = "" + portNumber
        outcome.success_memory = normalizeInput(cachedEntry.memory).trim
        outcome.success_unsafe = normalizeInput(cachedEntry.unsafe).trim
        appendLine(outcome.notes, "Cached signature hit [" + variantLabel + "]: " + cachedEntry.memory + " / " + cachedEntry.unsafe + " -> " + resultType)
        if variantExtraArg != "" then appendLine(outcome.notes, "Overflow extra arg: " + variantExtraArg)
        if resultType == "string" then appendLine(outcome.notes, "Result value: " + normalizeInput(result))
        if resultType == "number" then appendLine(outcome.notes, "Result value: " + result)

        if resultType == "shell" then
          recordAcceptedTerminalAccess(result, targetRecord, runState)
          accessLevel = classifyTerminalAccessLevel(result, runState.target.target_user)
          if exactTargetMode and accessLevel != "root" then
            if fallbackShellResult == null or accessLevelScore(accessLevel) > accessLevelScore(fallbackShellAccessLevel) then
              fallbackShellResult = result
              fallbackShellResultType = resultType
              fallbackShellStatus = classifyAttackStatus(resultType, result)
              fallbackShellAccessLevel = accessLevel
              fallbackShellPort = "" + portNumber
              fallbackShellMemory = normalizeInput(cachedEntry.memory).trim
              fallbackShellUnsafe = normalizeInput(cachedEntry.unsafe).trim
            end if
            appendLine(outcome.notes, "Exact target " + accessLevel + " shell obtained; continuing same-host exploit search for stronger access.")
            continue
          end if
        end if

        if resultType == "computer" then
          escalationOutcome = attemptComputerShellEscalation(runtimeContext.shell, result, targetRecord, runState)
          outcome.escalation_status = escalationOutcome.status
          for noteLine in escalationOutcome.notes
            appendLine(outcome.notes, noteLine)
          end for

          if escalationOutcome.shell != null then
            outcome.result = escalationOutcome.shell
            outcome.result_type = escalationOutcome.access_type
            outcome.status = escalationOutcome.status
            outcome.ports_tried_text = outcome.ports_tried.join(", ")
            return outcome
          end if

          if fallbackComputerResult == null then
            fallbackComputerResult = result
            fallbackComputerPort = "" + portNumber
            fallbackComputerMemory = normalizeInput(cachedEntry.memory).trim
            fallbackComputerUnsafe = normalizeInput(cachedEntry.unsafe).trim
            fallbackComputerEscalationStatus = escalationOutcome.status
          end if
          appendLine(outcome.notes, "Computer access preserved; continuing exploit search for direct shell.")
          continue
        end if

        if resultType == "file" then
          fileOutcome = handleFileAttackResult(runtimeContext, runState, targetRecord, result, variantExtraArg)
          outcome.status = fileOutcome.status
          filePriority = scoreFileAttackOutcome(fileOutcome)
          for noteLine in fileOutcome.notes
            appendLine(outcome.notes, noteLine)
          end for
          if filePriority > fallbackFilePriority then
            fallbackFileResult = result
            fallbackFileStatus = fileOutcome.status
            fallbackFilePriority = filePriority
            fallbackFilePort = "" + portNumber
            fallbackFileMemory = normalizeInput(cachedEntry.memory).trim
            fallbackFileUnsafe = normalizeInput(cachedEntry.unsafe).trim
          end if
          appendLine(outcome.notes, "File access preserved; continuing exploit search for shell/computer.")
          continue
        end if

        if isAcceptedAttackResult(resultType, result) then
          outcome.ports_tried_text = outcome.ports_tried.join(", ")
          return outcome
        end if
      end for
    end for

    memories = runtimeContext.meta.scan(remoteLib)
    if memories == null or memories.len == 0 then
      appendLine(outcome.notes, "No vulnerable memory zones found on " + attackAddress + ":" + portNumber)
      continue
    end if

    outcome.memory_zones = outcome.memory_zones + memories.len
    appendLine(outcome.notes, "Memory zones on " + attackAddress + ":" + portNumber + ": " + memories.len)

    for memoryAddress in memories
      yield
      scanInfo = runtimeContext.meta.scan_address(remoteLib, memoryAddress)
      outcome.surface_records = outcome.surface_records + dumpExploitSurface(targetRecord, runtimeContext, runState, portNumber, remoteLib, memoryAddress, scanInfo, "remote-service")
      unsafeValues = extractUnsafeValues(scanInfo)
      if unsafeValues == null or unsafeValues.len == 0 then continue

      for unsafeValue in unsafeValues
        yield
        if outcome.overflow_attempts >= maxAttempts then
          outcome.status = "attempt-limit"
          appendLine(outcome.notes, "Attack attempt limit reached while testing discovered unsafe values.")
          outcome.ports_tried_text = outcome.ports_tried.join(", ")
          return outcome
        end if

        overflowVariants = buildOverflowVariants(runState, targetRecord, portNumber)
        for overflowVariant in overflowVariants
          yield
          if outcome.overflow_attempts >= maxAttempts then
            outcome.status = "attempt-limit"
            appendLine(outcome.notes, "Attack attempt limit reached while testing discovered unsafe values.")
            outcome.ports_tried_text = outcome.ports_tried.join(", ")
            return outcome
          end if

          variantLabel = normalizeInput(overflowVariant.label).trim
          variantExtraArg = normalizeInput(overflowVariant.extra_arg).trim
          tryKey = buildOverflowTryKey(memoryAddress, unsafeValue, variantLabel, variantExtraArg)
          if listHasValue(triedSignatures, tryKey) then continue

          triedSignatures.push(tryKey)
          outcome.overflow_attempts = outcome.overflow_attempts + 1
          result = runOverflowVariant(remoteLib, memoryAddress, unsafeValue, variantExtraArg)
          if result == null then continue

          resultType = typeof(result)
          addSignatureCacheRecord(signatureCache, outcome.lib_name, outcome.lib_version, portNumber, memoryAddress, unsafeValue, resultType)
          outcome.result = result
          outcome.raw_result_type = resultType
          outcome.result_type = resultType
          outcome.status = classifyAttackStatus(resultType, result)
          outcome.success_port = "" + portNumber
          outcome.success_memory = normalizeInput(memoryAddress).trim
          outcome.success_unsafe = normalizeInput(unsafeValue).trim
          appendLine(outcome.notes, "Exploit hit [" + variantLabel + "]: " + memoryAddress + " / " + unsafeValue + " -> " + resultType)
          if variantExtraArg != "" then appendLine(outcome.notes, "Overflow extra arg: " + variantExtraArg)
          if resultType == "string" then appendLine(outcome.notes, "Result value: " + normalizeInput(result))
          if resultType == "number" then appendLine(outcome.notes, "Result value: " + result)

          if resultType == "shell" then
            recordAcceptedTerminalAccess(result, targetRecord, runState)
            accessLevel = classifyTerminalAccessLevel(result, runState.target.target_user)
            if exactTargetMode and accessLevel != "root" then
              if fallbackShellResult == null or accessLevelScore(accessLevel) > accessLevelScore(fallbackShellAccessLevel) then
                fallbackShellResult = result
                fallbackShellResultType = resultType
                fallbackShellStatus = classifyAttackStatus(resultType, result)
                fallbackShellAccessLevel = accessLevel
                fallbackShellPort = "" + portNumber
                fallbackShellMemory = normalizeInput(memoryAddress).trim
                fallbackShellUnsafe = normalizeInput(unsafeValue).trim
              end if
              appendLine(outcome.notes, "Exact target " + accessLevel + " shell obtained; continuing same-host exploit search for stronger access.")
              continue
            end if
          end if

          if resultType == "computer" then
            escalationOutcome = attemptComputerShellEscalation(runtimeContext.shell, result, targetRecord, runState)
            outcome.escalation_status = escalationOutcome.status
            for noteLine in escalationOutcome.notes
              appendLine(outcome.notes, noteLine)
            end for

            if escalationOutcome.shell != null then
              outcome.result = escalationOutcome.shell
              outcome.result_type = escalationOutcome.access_type
              outcome.status = escalationOutcome.status
              outcome.ports_tried_text = outcome.ports_tried.join(", ")
              return outcome
            end if

            if fallbackComputerResult == null then
              fallbackComputerResult = result
              fallbackComputerPort = "" + portNumber
              fallbackComputerMemory = normalizeInput(memoryAddress).trim
              fallbackComputerUnsafe = normalizeInput(unsafeValue).trim
              fallbackComputerEscalationStatus = escalationOutcome.status
            end if
            appendLine(outcome.notes, "Computer access preserved; continuing exploit search for direct shell.")
            continue
          end if

          if resultType == "file" then
            fileOutcome = handleFileAttackResult(runtimeContext, runState, targetRecord, result, variantExtraArg)
            outcome.status = fileOutcome.status
            filePriority = scoreFileAttackOutcome(fileOutcome)
            for noteLine in fileOutcome.notes
              appendLine(outcome.notes, noteLine)
            end for
            if filePriority > fallbackFilePriority then
              fallbackFileResult = result
              fallbackFileStatus = fileOutcome.status
              fallbackFilePriority = filePriority
              fallbackFilePort = "" + portNumber
              fallbackFileMemory = normalizeInput(memoryAddress).trim
              fallbackFileUnsafe = normalizeInput(unsafeValue).trim
            end if
            appendLine(outcome.notes, "File access preserved; continuing exploit search for shell/computer.")
            continue
          end if

          if isAcceptedAttackResult(resultType, result) then
            outcome.ports_tried_text = outcome.ports_tried.join(", ")
            return outcome
          end if
        end for
      end for
    end for
  end for

  if fallbackShellResult != null then
    outcome.status = fallbackShellStatus
    outcome.result = fallbackShellResult
    outcome.raw_result_type = fallbackShellResultType
    outcome.result_type = fallbackShellResultType
    outcome.success_port = fallbackShellPort
    outcome.success_memory = fallbackShellMemory
    outcome.success_unsafe = fallbackShellUnsafe
    outcome.ports_tried_text = outcome.ports_tried.join(", ")
    return outcome
  end if

  manualAssistOutcome = manualExploitAssist(targetRecord, runtimeContext, runState)
  if manualAssistOutcome != null then
    outcome.manual_assist_status = normalizeInput(manualAssistOutcome.status).trim
    outcome.manual_assist_port = normalizeInput(manualAssistOutcome.selected_port).trim
    outcome.manual_assist_memory = normalizeInput(manualAssistOutcome.selected_memory).trim
    outcome.manual_assist_unsafe = normalizeInput(manualAssistOutcome.selected_unsafe).trim
    if outcome.manual_assist_port != "" and not listHasValue(outcome.ports_tried, outcome.manual_assist_port) then outcome.ports_tried.push(outcome.manual_assist_port)
    outcome.sessions_opened = outcome.sessions_opened + manualAssistOutcome.sessions_opened
    outcome.overflow_attempts = outcome.overflow_attempts + manualAssistOutcome.overflow_attempts
    for noteLine in manualAssistOutcome.notes
      appendLine(outcome.notes, noteLine)
    end for

    if manualAssistOutcome.keep_result and manualAssistOutcome.result != null then
      outcome.status = manualAssistOutcome.status
      outcome.result = manualAssistOutcome.result
      outcome.raw_result_type = manualAssistOutcome.raw_result_type
      outcome.result_type = manualAssistOutcome.result_type
      outcome.escalation_status = manualAssistOutcome.escalation_status
      outcome.success_port = normalizeInput(manualAssistOutcome.selected_port).trim
      outcome.success_memory = normalizeInput(manualAssistOutcome.selected_memory).trim
      outcome.success_unsafe = normalizeInput(manualAssistOutcome.selected_unsafe).trim
      outcome.ports_tried_text = outcome.ports_tried.join(", ")
      return outcome
    end if
  end if

  if fallbackComputerResult != null then
    outcome.status = "computer"
    outcome.result = fallbackComputerResult
    outcome.raw_result_type = "computer"
    outcome.result_type = "computer"
    outcome.escalation_status = fallbackComputerEscalationStatus
    outcome.success_port = fallbackComputerPort
    outcome.success_memory = fallbackComputerMemory
    outcome.success_unsafe = fallbackComputerUnsafe
    outcome.ports_tried_text = outcome.ports_tried.join(", ")
    return outcome
  end if

  if fallbackFileResult != null then
    outcome.status = fallbackFileStatus
    outcome.result = fallbackFileResult
    outcome.raw_result_type = "file"
    outcome.result_type = "file"
    outcome.success_port = fallbackFilePort
    outcome.success_memory = fallbackFileMemory
    outcome.success_unsafe = fallbackFileUnsafe
    outcome.ports_tried_text = outcome.ports_tried.join(", ")
    return outcome
  end if

  if outcome.result != null then
    outcome.ports_tried_text = outcome.ports_tried.join(", ")
    return outcome
  end if

  outcome.status = "no-hit"
  outcome.ports_tried_text = outcome.ports_tried.join(", ")
  return outcome
end function

runConfig = buildRunConfig()
runtimeContext = buildRuntimeContext(runConfig.lib_dir)
runConfig = promptForMissingInputs(runConfig)
targetContext = buildTargetContext(runConfig, runtimeContext)
runConfig.mode = resolveMode(runConfig, targetContext)
outputFiles = prepareOutputFiles(runtimeContext, runConfig)
if outputFiles == null then exit("Unable to prepare output files")

runState = buildInitialRunState(runtimeContext, runConfig, targetContext, outputFiles)
printStartupSummary(runtimeContext, runConfig, targetContext, outputFiles)
startupReportResult = writeStartupReport(runtimeContext, runConfig, targetContext, outputFiles)
if startupReportResult != 1 then exit("Unable to write startup report: " + normalizeInput(startupReportResult))

discoveredHosts = discoverTargets(targetContext, runtimeContext, runState)
rankedHosts = rankTargets(discoveredHosts, targetContext, runState)
selectedHostIp = promptTargetHostMenu(rankedHosts, targetContext, runConfig, runState)
if selectedHostIp == "" and rankedHosts != null and rankedHosts.len > 0 then selectedHostIp = rankedHosts[0].ip
runState.selected_host_ip = selectedHostIp
selectedHostRecord = findHostRecordByIp(rankedHosts, selectedHostIp)
runState.selected_host_record = selectedHostRecord

saveHostCacheResult = saveHostCache(outputFiles.host_cache_file, rankedHosts)
if isError(saveHostCacheResult) then exit("Unable to save host cache: " + saveHostCacheResult)

printDiscoverySummary(rankedHosts, selectedHostIp)

attackResult = attackRankedTargets(rankedHosts, selectedHostRecord, runtimeContext, runState)
runState.attack_result = attackResult

credentialResult = null
if shouldDeferCredentialReuseToRouterHandoff(runState) then
  credentialResult = {
    "status": "deferred-router-handoff",
    "shell": null,
    "host_ip": "",
    "user": "",
    "source_host": "",
    "attempts": 0,
    "successes": 0,
    "scanned_files": 0,
    "password_candidates": 0,
    "loot_records": 0,
    "notes": ["Credential reuse deferred until router handoff completes."],
  }
else
  credentialResult = attemptCredentialReuse(runtimeContext, runState, attackResult)
end if
runState.credential_result = credentialResult
printCredentialSummary(credentialResult)

finalResult = finalizeAcceptedAccess(runState)
printFinalSummary(finalResult)

saveSignatureCacheResult = saveSignatureCache(outputFiles.signature_cache_file, runState.signature_cache)
if isError(saveSignatureCacheResult) then exit("Unable to save signature cache: " + saveSignatureCacheResult)

saveCredentialCacheResult = saveCredentialCache(outputFiles.credential_cache_file, runState.credential_cache)
if isError(saveCredentialCacheResult) then exit("Unable to save credential cache: " + saveCredentialCacheResult)

saveSurfaceCacheResult = saveSurfaceCache(outputFiles.surface_cache_file, runState)
if isError(saveSurfaceCacheResult) then exit("Unable to save surface cache: " + saveSurfaceCacheResult)

saveLootCacheResult = saveLootCache(outputFiles.loot_cache_file, runState)
if isError(saveLootCacheResult) then exit("Unable to save loot cache: " + saveLootCacheResult)

discoveryReportResult = writeDiscoveryReport(runtimeContext, runConfig, targetContext, outputFiles, discoveredHosts, rankedHosts, selectedHostIp, attackResult, credentialResult, finalResult)
if isError(discoveryReportResult) then exit("Unable to write discovery report: " + discoveryReportResult)

print("Phase 8 implementation complete.")
print("Ready for Phase 8 runtime validation.")
